{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sesi",
  "scopeName": "source.sesi",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#brackets"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sesi",
          "match": "//.*$"
        },
        {
          "name": "comment.block.sesi",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sesi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sesi",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.sesi",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sesi",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sesi",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.sesi",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sesi",
          "match": "\\b(if|else|while|for|in|to|return|break|continue|try|catch|finally|async|await|allow|with)\\b"
        },
        {
          "name": "constant.other.property.sesi",
          "match": "\\b(temperature|max_tokens|top_p|top_k|thinkingLevel|cache|search|ratio|size|output_type|file_type|max_retries|stream|stop|seed)\\b"
        },
        {
          "name": "keyword.declaration.sesi",
          "match": "\\b(let|const|fn|import|from|export)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.sesi",
          "match": "\\b(number|string|bool|null|array|object)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.sesi",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "constant.language.context.sesi",
          "match": "\\b(media|audio|video|text|doc)\\b"
        },
        {
          "name": "constant.other.math.sesi",
          "match": "\\b(PI|E|INFINITY|NaN)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.reasoning.sesi",
          "match": "\\b(set_alias|model|image|workflow)\\b"
        },
        {
          "name": "support.function.builtin.general.sesi",
          "match": "\\b(print|memory|memory_search|memory_trim|prompt|structured_output|tool_call|define_tool|web_send|web_get|list_tools|error_type|raise_error|multi_req|args|len|range|type|str|num|bool|keys|values|push|pop|join|split|to_upper|to_lower|trim|slice|swap|contains|locate|map|filter|reduce|find|retry|read_file|write_file|write_image|convert|list_dir|make_dir|rename|archive|trash|spawn|exec|sesi|python|js|html|time|env|random|exp|sin|cos|tan|sqrt|floor|ceil|abs|pow|log|now|sleep|format|parse|stringify|to_json|from_json|listen|live|db_open|launch|input|play|beep|synth|save|sequence|mix|comp|render|sf2|chord|scale|transpose|duration|bar|clear|circle|rect|line|text|save_svg|ellipse|polygon|path|gradient|style|raw|name|arity|is_function|is_array|is_object|is_string|is_number|is_bool|is_null|length|starts_with|ends_with|index_of|repeat|includes|reverse|sort|unique|flatten)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.sesi",
          "match": "->"
        },
        {
          "name": "keyword.operator.logical.sesi",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.comparison.sesi",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.sesi",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.sesi",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },
    "brackets": {
      "patterns": [
        {
          "name": "meta.brace.round.sesi",
          "match": "\\(|\\)"
        },
        {
          "name": "meta.brace.square.sesi",
          "match": "\\[|\\]"
        },
        {
          "name": "meta.brace.curly.sesi",
          "match": "\\{|\\}"
        }
      ]
    }
  }
}
