{
  "name": "sesi-syntax",
  "displayName": "Sesi Developer Kit",
  "description": "Native syntax highlighting and rich hover tooltips for the Sesi Programming Language.",
  "version": "1.6.5",
  "publisher": "Misterscan",
  "repository": {
    "type": "git",
    "url": "https://github.com/Misterscan/sesi.git"
  },
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sesi",
        "aliases": ["Sesi", "sesi"],
        "extensions": [".sesi"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sesi",
        "scopeName": "source.sesi",
        "path": "./syntaxes/sesi.tmLanguage.json"
      }
    ]
  }
}
