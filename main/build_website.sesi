let page_title = "Sesi"
let tagline = "A High-Performance Systems Programming Language"
let features = "Distributed Orchestration, Native System Primitives, Indestructible Logic, Filesystem-as-a-Bus, Integrated Reasoning, Atomic Coordination"
try {
  print "Generating Sesi Systems Language landing page..."
  let html = model("gemini-3.1-pro-preview") {"temperature": 0.4, "max_tokens": 8192} {"You are a visionary systems engineer and frontend developer. Create a stunning, high-density dark theme landing page for Sesi. Topic: " page_title " Tagline: " tagline " Features: " features " Branding Strategy: Highlight Systems Orchestration and the Double-Check Write pattern. Neon Cyan/Purple/Green accents. Return RAW HTML only, no markdown."}
  write_file("index.html", html)
  print "Website successfully built!"
} catch (e) {
  print "Error:"
  print e
}