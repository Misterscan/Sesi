/* Sesi Web Scraper
Fetches a webpage, validates its URL, extracts structured metadata,
saves a JSON data record, and compiles a Markdown report. 
Usage:
  sesi scraper.sesi [url]
*/

allow "std/time" in with Time
allow "std/browser" in with Browser
let currentTime = Time.format(Time.now(), {"locale": "en-US", "dateStyle": "medium", "timeStyle": "short"})

// Ensure reports directory exists
let outputDir = "reports"
let existing = list_dir(outputDir)
if type(existing) == "null" {
  make_dir(outputDir)
}

// Retrieve target URL from arguments or default to Hacker News
let target_url = "https://news.ycombinator.com/"
if len(args) > 0 {
  target_url = args[0]
}

// Define url validation function
fn validate_url(url) {
  let parts = split(url, "://")
  if len(parts) > 1 {
    let scheme = parts[0]
    if scheme == "http" || scheme == "https" {
      return true
    }
  }
  return false
}

// Register as a custom tool
define_tool("url_validator", validate_url, "Validates if the URL has http or https scheme")

// Validate the URL using the registered tool
let isValid = tool_call(url_validator)(target_url)
if !isValid {
  print "Error: Invalid URL specified:" target_url
  print "The scraper requires a valid URL starting with http:// or https://"
  raise_error("ValidationError", "Invalid URL scheme")
}

print "🌐 Fetching webpage and extracting metadata via browser automation from:" target_url
let result = {}
try {
  let browser = Browser.launch({"headless": true})
  let page = browser.newPage()
  page.goto(target_url)
  page.wait_for_timeout(1000)

  // Extract all details directly from the page context using browser APIs
  let extractScript = "(() => {
    const descMeta = document.querySelector('meta[name=\"description\"]') || document.querySelector('meta[property=\"og:description\"]');
    let siteTopic = descMeta ? descMeta.getAttribute('content') : '';
    if (siteTopic === '') {
      siteTopic = 'News and General Content';
    }

    // Extract headlines
    let elements = Array.from(document.querySelectorAll('h1, h2, h3, .titleline > a, .storylink'));
    let headlines = Array.from(new Set(
      elements.map(el => el.innerText.trim()).filter(t => t.length > 10)
    )).slice(0, 10);

    if (headlines.length === 0) {
      headlines = [document.title];
    }

    // Extract paragraphs/content
    let pElements = Array.from(document.querySelectorAll('p, td.title, .entry-content')).slice(0, 5);
    let keyContent = pElements.map(p => p.innerText.trim()).filter(t => t.length > 20).join('\\n\\n').slice(0, 1000);
    if (keyContent === '') {
      keyContent = 'No key content paragraphs found.';
    }

    let highlights = headlines[0] || 'No headlines found.';

    return {
      'pageTitle': document.title || 'Untitled Page',
      'siteTopic': siteTopic,
      'headlines': headlines,
      'keyContent': keyContent,
      'highlights': highlights
    };
  })()"

  result = page.evaluate(extractScript)
  let cleanPath = swap(target_url, "https://", "")
  page.screenshot({"path": outputDir + "/" + cleanPath + currentTime + "-screenshot.png"})
  page.close()
  browser.close()
} catch (e) {
  print "❌ Failed to retrieve page content:" e
  raise_error("NetworkError", "Failed to retrieve webpage content")
}

let pageTitle = result["pageTitle"]
let siteTopic = result["siteTopic"]
let headlines = result["headlines"]
let keyContent = result["keyContent"]
let highlights = result["highlights"]

print "✅ Extraction finished successfully!"
print "Page Title:" pageTitle
print "Primary Topic:" siteTopic
print "Number of headlines found:" len(headlines)

// Construct structured JSON database entry
let outputData = {
  "url": target_url,
  "pageTitle": pageTitle,
  "siteTopic": siteTopic,
  "scrapedAt": currentTime,
  "headlines": headlines,
  "keyContent": keyContent,
  "highlights": highlights
}

try {
  write_file(outputDir + "/scraped_results.json", to_json(outputData))
} catch (e) {
  print "Error writing results JSON:" e
}
print "💾 Saved database entry to " outputDir "/scraped_results.json"

// Compile Markdown report
let mdHeadlines = ""
for h in headlines {
  mdHeadlines = mdHeadlines + "- " + h + "\n"
}

let timestamp = Time.format(Time.now(), {"locale": "en-US", "dateStyle": "medium", "timeStyle": "medium"})
prompt reportBody {"# Web Scraper Report

- **Source URL**: " target_url "
- **Page Title**: " pageTitle "
- **Topic Category**: " siteTopic "
- **Scraped At**: " timestamp "

## Extracted Headlines

" mdHeadlines "

## Key Content

" keyContent "

## Highlights

" highlights}

try {
  write_file(outputDir + "/" + pageTitle + "-report-" + timestamp + ".md", reportBody)
} catch (e) {
  print "Error writing report Markdown:" e
}
print "📄 Compiled and saved report to" outputDir "/" pageTitle "-report-" timestamp ".md"