// Advanced Sesi Demo
// Demonstrating Memory, File I/O, and AI features

memory reportLog {
  "Log of AI operations:\n"
}

fn logAction(action: string) {
  reportLog = reportLog + "- " + action + "\n"
}

// 1. Setup data
let dataPath = "main/data.txt"
write_file(dataPath, "Project X Status: Delayed. Reason: Scope creep. Priority: High.")
logAction("Created data file")

// 2. Read and analyze
let data = read_file(dataPath)
logAction("Read data file")

print("Data read: ", data)

// 3. AI Analysis with Structured Output
// NOTE: Using IDENTIFIERS for schema keys as required by parser.ts
let analysis = structured_output({
  status: string,
  priority: string,
  riskLevel: number,
  recommendation: string
})(
  model("gemini-3.1-flash-lite") {
    "Analyze the following project status data and return JSON:\n"
    data
  }
)
logAction("Performed AI analysis")

print("Analysis Results:")
print("Status: ", analysis.status)
print("Priority: ", analysis.priority)
print("Risk Level: ", str(analysis.riskLevel))
print("Recommendation: ", analysis.recommendation)

// 4. Generate final report
let finalReport = model("gemini-3.1-flash-lite") {
  "temperature": 0.3
} {
  "Create a professional summary report based on this analysis:\n"
  str(analysis)
  "\nContext Log:\n"
  reportLog
}
logAction("Generated final report")

write_file("main/report.txt", finalReport)
print("\nFinal report saved to main/report.txt")
print("\n--- Final Memory Log ---")
print(reportLog)
