// main/sesi_db_chatbot.sesi
// Dynamically indexes the sesi-db knowledge base, trains on-the-fly, and answers queries!

// ==================================================
// 💬 1. CHOOSE YOUR ADVANCED TECHNICAL QUERY HERE!
// (Test it with custom phrases containing our keywords!)
let queryText = "how do I parse a json string?"
try {
  queryText = read_file("query.txt")
} catch (e) {}
let fileContext = ""
try {
  fileContext = read_file("help_context.txt")
} catch (e) {}
// ==================================================

print "Loading Sesi Co-Pilot..."

// Maintains context across multiple queries so the co-pilot remembers what you previously asked.
memory chatHistory {"You are the Sesi Co-Pilot, an expert assistant for the Sesi programming language. You help users write correct, idiomatic Sesi code. Be concise and conversational."}

// Load persisted history from disk if it exists
try {
  chatHistory = read_file("sesi-db/chat_history.txt")
} catch (e) {}

// Auto-summarize when history gets too long (saves tokens)
fn summarizeHistory() {
  let summary = model("gemini-3.1-flash-lite") {temperature: 0, max_tokens: 300} {"Summarize this conversation history into key facts and context. Be very concise: " chatHistory}
  chatHistory = "Previous conversation summary: " + summary
}

// Sigmoid math activation
fn activate(x) {
  return 1.0 / (1.0 + exp(0.0 - x))
}

// Sigmoid derivative for backpropagation
fn derivative(y) {
  return y * (1.0 - y)
}

// 68-Dimensional Bag-of-Words Vocabulary Vectorizer
// Tracks only official Sesi language keywords, compiler builtins, and native standard library exports.
fn vectorize(text) {
  let vec = []
  let k = 0
  while k < 68 {
    push(vec, 0.0)
    k = k + 1
  }
  
  let raw_words = split(text, " ")
  let words = []
  
  let w = 0
  let num_raw = len(raw_words)
  while w < num_raw {
    let word = raw_words[w]
    let parts_nl = split(word, "\n")
    let p = 0
    while p < len(parts_nl) {
      let sub_word1 = parts_nl[p]
      let parts_t = split(sub_word1, "\t")
      let t = 0
      while t < len(parts_t) {
        let sub_word2 = parts_t[t]
        let chars = split(sub_word2, "")
        let clean_tok = ""
        let c = 0
        while c < len(chars) {
          let char = chars[c]
          if char != "(" {
            if char != ")" {
              if char != "{" {
                if char != "}" {
                  if char != "[" {
                    if char != "]" {
                      if char != ";" {
                        if char != "," {
                          if char != "\r" {
                            if char != "\"" {
                              if char != "'" {
                                clean_tok = clean_tok + char
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
          c = c + 1
        }
        if len(clean_tok) > 0 {
          push(words, clean_tok)
        }
        t = t + 1
      }
      p = p + 1
    }
    w = w + 1
  }

  let i = 0
  while i < len(words) {
    let tok = words[i]
    if tok == "print" { vec[0] = 1.0 }
    if tok == "str" { vec[1] = 1.0 }
    if tok == "type" { vec[2] = 1.0 }
    if tok == "num" { vec[3] = 1.0 }
    if tok == "bool" { vec[4] = 1.0 }
    if tok == "from_json" { vec[5] = 1.0 }
    if tok == "to_json" { vec[6] = 1.0 }
    if tok == "len" { vec[7] = 1.0 }
    if tok == "read_file" { vec[8] = 1.0 }
    if tok == "write_file" { vec[9] = 1.0 }
    if tok == "write_image" { vec[10] = 1.0 }
    if tok == "list_dir" { vec[11] = 1.0 }
    if tok == "make_dir" { vec[12] = 1.0 }
    if tok == "exp" { vec[13] = 1.0 }
    if tok == "random" { vec[14] = 1.0 }
    if tok == "let" { vec[15] = 1.0 }
    if tok == "const" { vec[16] = 1.0 }
    if tok == "fn" { vec[17] = 1.0 }
    if tok == "if" { vec[18] = 1.0 }
    if tok == "else" { vec[19] = 1.0 }
    if tok == "while" { vec[20] = 1.0 }
    if tok == "for" { vec[21] = 1.0 }
    if tok == "return" { vec[22] = 1.0 }
    if tok == "break" { vec[23] = 1.0 }
    if tok == "continue" { vec[24] = 1.0 }
    if tok == "try" { vec[25] = 1.0 }
    if tok == "catch" { vec[26] = 1.0 }
    if tok == "finally" { vec[27] = 1.0 }
    if tok == "import" { vec[28] = 1.0 }
    if tok == "export" { vec[29] = 1.0 }
    if tok == "memory" { vec[30] = 1.0 }
    if tok == "sleep" { vec[31] = 1.0 }
    if tok == "now" { vec[32] = 1.0 }
    if tok == "model" { vec[33] = 1.0 }
    if tok == "image" { vec[34] = 1.0 }
    if tok == "structured_output" { vec[35] = 1.0 }
    if tok == "tool_call" { vec[36] = 1.0 }
    if tok == "spawn" { vec[37] = 1.0 }
    if tok == "exec" { vec[38] = 1.0 }
    if tok == "time" { vec[39] = 1.0 }
    if tok == "range" { vec[40] = 1.0 }
    if tok == "push" { vec[41] = 1.0 }
    if tok == "pop" { vec[42] = 1.0 }
    if tok == "join" { vec[43] = 1.0 }
    if tok == "split" { vec[44] = 1.0 }
    if tok == "keys" { vec[45] = 1.0 }
    if tok == "values" { vec[46] = 1.0 }
    if tok == "array" { vec[47] = 1.0 }
    if tok == "PI" { vec[48] = 1.0 }
    if tok == "E" { vec[49] = 1.0 }
    if tok == "sin" { vec[50] = 1.0 }
    if tok == "cos" { vec[51] = 1.0 }
    if tok == "tan" { vec[52] = 1.0 }
    if tok == "sqrt" { vec[53] = 1.0 }
    if tok == "floor" { vec[54] = 1.0 }
    if tok == "ceil" { vec[55] = 1.0 }
    if tok == "abs" { vec[56] = 1.0 }
    if tok == "pow" { vec[57] = 1.0 }
    if tok == "log" { vec[58] = 1.0 }
    if tok == "parse" { vec[59] = 1.0 }
    if tok == "stringify" { vec[60] = 1.0 }
    if tok == "workflow" { vec[61] = 1.0 }
    if tok == "set_alias" { vec[62] = 1.0 }
    if tok == "define_tool" { vec[63] = 1.0 }
    if tok == "list_tools" { vec[64] = 1.0 }
    if tok == "error_type" { vec[65] = 1.0 }
    if tok == "raise_error" { vec[66] = 1.0 }
    if tok == "multi_req" { vec[67] = 1.0 }
    i = i + 1
  }
  return vec
}

let trained_model_path = "sesi-db/trained_brain.json"
let has_trained_model = false
let weights = []
let biases = []
let database = []
let num_classes = 0

try {
  let raw = read_file(trained_model_path)
  let brain = from_json(raw)
  weights = brain["weights"]
  biases = brain["biases"]
  database = brain["database"]
  num_classes = len(database)
  has_trained_model = true
} catch (e) {}

if has_trained_model == false {
  print "⚠️  No pre-trained model found! Please execute training first: 'sesi main/train_neural_network.sesi'"
} else {
  let query_vec = vectorize(queryText)
  
  // Forward propagation on user query across all dynamic classes
  let outputs = []
  let j = 0
  while j < num_classes {
    let sum = 0.0
    let w_row = weights[j]
    let k = 0
    while k < 68 {
      sum = sum + (query_vec[k] * w_row[k])
      k = k + 1
    }
    let o = activate(sum + biases[j])
    push(outputs, o)
    j = j + 1
  }
  
  // Determine class index with highest score
  let best_class = 0
  let max_score = -1.0
  let j = 0
  while j < num_classes {
    if outputs[j] > max_score {
      max_score = outputs[j]
      best_class = j
    }
    j = j + 1
  }

  // 7. Output Dynamic Recommendation with Confidence Thresholding
  print "--------------------------------------------------"
  print "🤖 SESI CO-PILOT RESPONDING:"
  print "--------------------------------------------------"
  if max_score < 0.40 {
    print "🤔 Sesi's native synapses evaluated this query with low confidence: " + str(max_score)
    print "   It seems your question does not contain any Sesi keywords in our vocabulary!"
    print "   Please try asking about: 'print', 'str', 'files', 'json', 'model', 'image', or 'random'!"
  } else {
    let rec = database[best_class]
    let docs_list = list_dir("docs")
    let sesiDocs = ""
    let d = 0
    while d < len(docs_list) {
      let f_name = docs_list[d]
      let parts = split(f_name, ".")
      let ext = parts[len(parts) - 1]
      
      if ext == "md" {
        let doc_content = read_file("docs/" + f_name)
        sesiDocs = sesiDocs + "\n\n=== DOCUMENT: " + f_name + " ===\n" + doc_content
      }
      d = d + 1
    }
    
    // Auto-summarize if history exceeds ~3000 characters
    if len(chatHistory) > 3000 {
      summarizeHistory()
    }
    
    let ragPrompt = "Conversation History:\n" + chatHistory + "\n\nSesi Official Reference Documentation:\n" + sesiDocs + "\n\nUser Query: " + queryText + "\n\nActive File Context:\n" + fileContext + "\n\nMatched Context from Sesi DB:\nSummary: " + rec["summary"] + "\nKey Rules: " + rec["key_rules"] + "\n\nInstructions: Write a direct, beautiful, highly conversational response to the user's question using strictly the matched rules. If Active File Context is present, use it directly and talk about that file concretely. Be helpful and concise. Do not mention that you got this from a database—act as a supportive code copilot."
    
    let generated_response = model("gemini-3.1-flash-lite") {temperature: 0.2, max_tokens: 300} {ragPrompt}
    
    // Append this turn to conversational memory
    chatHistory = chatHistory + "\nUser: " + queryText + "\nAssistant: " + generated_response
    
    // Persist memory to disk for next session
    try {
      write_file("sesi-db/chat_history.txt", chatHistory)
    } catch (e) {}
    
    print "--------------------------------------------------"
    print generated_response
    print "--------------------------------------------------"
  }
}
