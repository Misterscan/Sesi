// Copy sesi-db-chatbot and all its .json files from sesi-db directory into the target folder.

let dbChatbotContent = safe_read("chatbot/sesi_db_chatbot.sesi")
if len(dbChatbotContent) > 0 {
  let dbChatbotDest = target + "/chatbot/sesi_db_chatbot.sesi"
  if safe_write(dbChatbotDest, dbChatbotContent) {
    print "✓ Copied sesi-db-chatbot to chatbot/sesi_db_chatbot.sesi"
  } else {
    print "⚠️ Failed to write sesi-db-chatbot"
  }
} else {
  print "⚠️ Could not read source sesi-db-chatbot"
}

let dbFiles = ["trained_brain.json"]
for file in dbFiles {
  let fileContent = safe_read("sesi-db/" + file)
  if len(fileContent) > 0 {
    let fileDest = target + "/sesi-db/" + file
    if safe_write(fileDest, fileContent) {
      print "✓ Copied" file "to sesi-db/" file
    } else {
      print "⚠️ Failed to write" file
    }
  } else {
    print "⚠️ Could not read source" file
  }
}

// Copy lint.sesi into target/lint.sesi
let lintContent = safe_read("bin/lint.sesi")
if len(lintContent) > 0 {
  let lintDest = target + "/bin/lint.sesi"
  if safe_write(lintDest, lintContent) {
    print "✓ Copied bin/lint.sesi to:" target "/bin/lint.sesi"
  } else {
    print "⚠️ Failed to write bin/lint.sesi"
  }
} else {
  print "⚠️ Could not read source bin/lint.sesi"
}

// Copy the examples folder and all its files
try {
  let examplesMainContent = list_dir(srcExamplesMainDir)
  for file in examplesMainContent {
    let fileContent = safe_read(srcExamplesMainDir + "/" + file)
    if len(fileContent) > 0 {
      let fileDest = examplesMainDir + "/" + file
      if safe_write(fileDest, fileContent) {
        print "✓ Copied" file "to" examplesMainDir "/" file
      } else {
        print "⚠️ Failed to write" file
      }
    } else {
      print "⚠️ Could not read source" file
    }
  }
} catch (e) {
  print "⚠️ Could not read source examples/main"
}

try {
  let examplesOptionalContent = list_dir(srcExamplesOptionalDir)
  for file in examplesOptionalContent {
    let fileContent = safe_read(srcExamplesOptionalDir + "/" + file)
    if len(fileContent) > 0 {
      let fileDest = examplesOptionalDir + "/" + file
      if safe_write(fileDest, fileContent) {
        print "✓ Copied" file "to" examplesOptionalDir "/" file
      } else {
        print "⚠️ Failed to write" file
      }
    } else {
      print "⚠️ Could not read source" file
    }
  }
} catch (e) {
  print "⚠️ Could not read source examples/optional"
}

// Copy test-runner.sesi to target/test-runner.sesi
let testRunnerContent = safe_read("bin/test-runner.sesi")
if len(testRunnerContent) > 0 {
  let testRunnerDest = target + "/bin/test-runner.sesi"
  if safe_write(testRunnerDest, testRunnerContent) {
    print "✓ Copied bin/test-runner.sesi to:" target "/bin/test-runner.sesi"
  } else {
    print "⚠️ Failed to write bin/test-runner.sesi"
  }
} else {
  print "⚠️ Could not read source bin/test-runner.sesi"
}

// Copy the getting-started folder and all its files
try {
  let gettingStartedContent = list_dir(srcGettingStartedDir)
  for file in gettingStartedContent {
    let fileContent = safe_read(srcGettingStartedDir + "/" + file)
    if len(fileContent) > 0 {
      let fileDest = gettingStartedDir + "/" + file
      if safe_write(fileDest, fileContent) {
        print "✓ Copied" file "to getting-started/" file
      } else {
        print "⚠️ Failed to write" file
      }
    } else {
      print "⚠️ Could not read source" file
    }
  }
} catch (e) {
  print "⚠️ Could not read source getting-started"
}

// Copy the getting-started/optional folder and all its files
try {
  let gettingStartedOptionalContent = list_dir(srcGettingStartedOptionalDir)
  for file in gettingStartedOptionalContent {
    let fileContent = safe_read(srcGettingStartedOptionalDir + "/" + file)
    if len(fileContent) > 0 {
      let fileDest = gettingStartedOptionalDir + "/" + file
      if safe_write(fileDest, fileContent) {
        print "✓ Copied" file "to" gettingStartedOptionalDir "/" file
      } else {
        print "⚠️ Failed to write" file
      }
    } else {
      print "⚠️ Could not read source" file
    }
  }
} catch (e) {
  print "⚠️ Could not read source getting-started/optional"
}

// Copy the helpers folder and all its files
try {
  let helpersContent = list_dir(srcHelpersDir)
  for file in helpersContent {
    let fileContent = safe_read(srcHelpersDir + "/" + file)
    if len(fileContent) > 0 {
      let fileDest = helpersDir + "/" + file
      if safe_write(fileDest, fileContent) {
        print "✓ Copied" file "to" helpersDir "/" file
      } else {
        print "⚠️ Failed to write" file
      }
    } else {
      print "⚠️ Could not read source" file
    }
  }
} catch (e) {
  print "⚠️ Could not read source helpers"
}

// Copy a specified file into the folder via CLi
let specifiedFile = ""
if len(args) > 1 {
  if args[1] != "-l" {
    specifiedFile = args[1]
  }
} else {
  specifiedFile = input("Copy a file into the folder? (optional, click enter to skip): ")
}

if len(specifiedFile) > 0 {
  let specifiedFileContent = safe_read(specifiedFile)
  if len(specifiedFileContent) > 0 {
    let fileParts = split(specifiedFile, "/")
    let filename = fileParts[len(fileParts) - 1]
    let specifiedFileDest = target + "/" + filename
    if safe_write(specifiedFileDest, specifiedFileContent) {
      print "✓ Copied" filename "to" specifiedFileDest
    } else {
      print "⚠️ Failed to write" filename
    }
  } else {
    print "⚠️ Could not read source" specifiedFile
  }
}

// Remove the file that we just copied from the source directory if requested
let options = input("Do you want to remove the copied file? (y/n): ")
let options2 = input("Do you want to install node_modules? (y/n): ")

let wantRemove = (options == "y")
let skipInstall = (options2 == "n")

for arg in args {
  if arg == "-rm" {
    wantRemove = true
  }
  if arg == "-no-install" {
    skipInstall = true
  }
}

if len(specifiedFile) > 0 && wantRemove {
  try {
    trash(specifiedFile, true)
    print "✓ Removed" specifiedFile "from source directory"
  } catch (err) {
    print "⚠️ Failed to remove" specifiedFile "from source directory."
  }
}

// Run npm install to fetch @google/genai and @dotenvx/dotenvx
if !skipInstall {
  print "⚡ Running npm install to pull node_modules..."
  try {
    exec("npm install --prefix \"" + target + "\"")
    print "✓ npm dependencies installed successfully!"
  } catch (err) {
    print "⚠️ Auto npm install failed. Please re-run with '-install' after scaffold finishes."
  }
}
print "🎉 Scaffolding complete! Run your new project using:"
print "   cd" target
print "   npm start"
