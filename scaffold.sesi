/* scaffold_project.sesi
 A Sesi project scaffolder that creates a self-contained Sesi project.
 Usage:
  sesi scaffold.sesi [target_folder_name] [-rm] [-no-install] [optional_file_to_copy]

  -rm: Removes the target folder if it exists (uses trash functionality)
  -no-install: Skips the npm install step
  optional_file_to_copy: Copies the specified file into the target folder

  Or simply run `sesi scaffold.sesi` and it will prompt you for the rest.
*/

allow "std/time" in with Time

// Resilience Helper: Safe file write with retry logic
fn safe_write(path: string, content: string) -> bool {
  let success = false
  let attempts = 0
  while !success && attempts < 3 {
    try {
      write_file(path, content)
      success = true
    } catch (err) {
      attempts = attempts + 1
      Time.sleep(100)
    }
  }
  return success
}

// Resilience Helper: Safe file read with retry logic
fn safe_read(path: string) -> string {
  let result = ""
  let success = false
  let attempts = 0
  while !success && attempts < 3 {
    try {
      result = read_file(path)
      success = true
    } catch (err) {
      attempts = attempts + 1
      Time.sleep(100)
    }
  }
  return result
}

// Parse target folder name
let target = "my-sesi-app"
if len(args) > 0 {
  target = args[0]
} else {
  target = input("Target Directory (default: my-sesi-app): ")
}
let cleanTarget = target
cleanTarget = swap(cleanTarget, "/", "")
cleanTarget = swap(cleanTarget, "./", "")
cleanTarget = swap(cleanTarget, "//", "")
cleanTarget = swap(cleanTarget, "\\", "")

// Add any paths you want to remove from the target directory name here (e.g., OS-specific or personal storage paths).
cleanTarget = swap(cleanTarget, "Volumes", "")
cleanTarget = swap(cleanTarget, "CrucialX9", "")
cleanTarget = swap(cleanTarget, "2026_Essentials", "")
cleanTarget = swap(cleanTarget, "Documents", "")
cleanTarget = swap(cleanTarget, "Desktop", "")
cleanTarget = swap(cleanTarget, "Users", "")
cleanTarget = swap(cleanTarget, "User", "")
cleanTarget = swap(cleanTarget, "C:\\", "")
cleanTarget = swap(cleanTarget, "D:\\", "")
cleanTarget = swap(cleanTarget, "E:\\", "")
cleanTarget = swap(cleanTarget, "F:\\", "")
cleanTarget = swap(cleanTarget, "G:\\", "")
cleanTarget = swap(cleanTarget, " ", "-")
cleanTarget = to_lower(cleanTarget)

print "⚡ Scaffolding new Sesi project in:" target

let agentsDir = target + "/.agents"
let rulesDir = agentsDir + "/rules"
let workflowsDir = agentsDir + "/workflows"
let examplesMainDir = target + "/examples/main"
let examplesOptionalDir = target + "/examples/optional"
let gettingStartedDir = target + "/getting-started"
let gettingStartedOptionalDir = gettingStartedDir + "/optional"
let helpersDir = target + "/helpers"

// Source directories
let srcExamplesMainDir = "examples/main"
let srcExamplesOptionalDir = "examples/optional"
let srcGettingStartedDir = "getting-started"
let srcGettingStartedOptionalDir = "getting-started/optional"
let srcHelpersDir = "helpers"

// Create base directories
try {
  make_dir(target)
  make_dir(target + "/bin")
  make_dir(target + "/chatbot")
  make_dir(target + "/sesi-db")
  make_dir(agentsDir)
  make_dir(rulesDir)
  make_dir(workflowsDir)
  make_dir(examplesMainDir)
  make_dir(examplesOptionalDir)
  make_dir(gettingStartedDir)
  make_dir(gettingStartedOptionalDir)
  make_dir(helpersDir)
  print "✓ Directories created"
} catch (err) {
  print "⚠️ Failed to create directories:" err
}

// Generate package.json
let desc = input("Description: ")
let author = input("Author: ")
let license = input("License (default: MIT): ")
if len(license) == 0 {
  license = "MIT"
}
prompt packageJson {"{
  \"name\": \"" cleanTarget "\",
  \"version\": \"1.0.0\",
  \"description\": \"" desc "\",
  \"main\": \"node_modules/@misterscan/sesi/dist/index.js\",
  \"bin\": {
    \"sesi\": \"node_modules/@misterscan/sesi/bin/sesi.js\"},
  \"license\": \"" license "\",
  \"author\": \"" author "\",
  \"private\": true,
  \"scripts\": {
    \"sesi\": \"node node_modules/@misterscan/sesi/bin/sesi.js\",
    \"start\": \"node node_modules/@misterscan/sesi/bin/sesi.js -l main.sesi\",
    \"eval\": \"node node_modules/@misterscan/sesi/bin/sesi.js -e\",
    \"help\": \"node node_modules/@misterscan/sesi/bin/sesi.js -h\",
    \"lint\": \"node node_modules/@misterscan/sesi/bin/sesi.js bin/lint.sesi\",
    \"encrypt\": \"node node_modules/@misterscan/sesi/bin/sesi.js -enc\",
    \"decrypt\": \"node node_modules/@misterscan/sesi/bin/sesi.js -dec\"
  },
  \"dependencies\": {
    \"@misterscan/sesi\": \"1.5.8\"
  },
    \"allowScripts\": {
    \"fsevents@2.3.2\": true,
    \"protobufjs@7.6.4\": true,
    \"@google/genai@2.10.0\": true
  }
}"}

if safe_write(target + "/package.json", packageJson) {
  print "✓ Generated package.json"
} else {
  print "⚠️ Failed to generate package.json"
}

// Generate .gitignore
prompt gitIgnore {"node_modules/
dist/
.env
.env.keys
.sesi_cache.json
"}

if safe_write(target + "/.gitignore", gitIgnore) {
  print "✓ Generated .gitignore"
} else {
  print "⚠️ Failed to generate .gitignore"
}

// Generate main.sesi (Starter Sesi script)
prompt mainSesi {'/* 
  Sesi Starter Script
  A basic playground to experiment with Sesi\'s syntax, variables, loops, and functions.

  Usage: 
    sesi starter.sesi [your_name]
*/

// 1. Variables and Types
let language = "Sesi"
let version = "1.5"
let features = ["Reasoning", "Embedded DB", "SVG Drawing", "Audio Synthesis"]

print "Welcome to" language "version" version "!"
print "----------------------------------------"

// 2. Command-Line Arguments & Interactive Input
let userName = ""
if len(args) > 0 {
  userName = args[0]
} else {
  userName = input("Please enter your name to begin: ")
}

print "Hello," userName "! Let\'s explore some Sesi syntax."
print ""

// 3. Functions
fn greet_user(name: string, lang: string) -> string {
  let upperName = to_upper(name)
  return "GREETINGS, " + upperName + "! YOU ARE NOW CODING IN " + to_upper(lang) + "."
}

let greeting = greet_user(userName, language)
print greeting
print ""

// 4. Loops and Collections
print "Here are some cool features of Sesi:"
for feature in features {
  print " - " feature
}
print ""

// 5. Numeric Ranges (starts at 1, goes up to but excluding 4)
print "Counting up to 3:"
for i = 1 to 4 {
  print "Count:" i
}
print ""

// 6. Prompt Blocks (Sesi\'s unique string composition)
let topic = "Sesi Programming"
prompt welcomeMessage {"Topic: " topic "
User: " userName "
Status: Ready for experimentation!"}

print welcomeMessage
'}

if safe_write(target + "/main.sesi", mainSesi) {
  print "✓ Generated main.sesi"
} else {
  print "⚠️ Failed to generate main.sesi"
}

// Generate README.md
prompt readMe {"# " cleanTarget "

" desc "

## Structure

* `bin/` - Sesi lint engine and test engine.
* `helpers/` - Helper scripts for file manipulation and other tasks.
* `.agents/` - AI agent configuration files.
* `env.example` - Environment variables.
* `main.sesi` - Starter script to run immediately.

## Commands

To execute your Sesi program:

```bash
npm start
```

To run inline Sesi code evaluations:

```bash
npm run eval \"print 'Hello from eval'\"
```

To run the linter:

```bash
npm run lint
```

To encrypt a file:

```bash
npm run encrypt <filename>
```

To decrypt a file:

```bash
npm run decrypt <filename>
```
"}

if safe_write(target + "/README.md", readMe) {
  print "✓ Generated README.md"
} else {
  print "⚠️ Failed to generate README.md"
}

// Copy GUIDE.md to target/GUIDE.md
let guideContent = safe_read("GUIDE.md")
if len(guideContent) > 0 {
  if safe_write(target + "/GUIDE.md", guideContent) {
    print "✓ Copied GUIDE.md"
  } else {
    print "⚠️ Failed to copy GUIDE.md"
  }
}

// Generate .agents/rules/sesi-must-read.md
prompt sesiMustReadRules {'---
trigger: always_on
---

## Agent Debug Protocol (MANDATORY)

When AI agents write or edit `.sesi` scripts, they must use this debugging loop:

1. **Draft in file, isolate risky snippet:** Identify the smallest parser/runtime-risky block (prompt block, model call, object schema, loop, etc.).
2. **Validate snippet with eval mode first:** Run `npm run eval "sesi code"` to test the isolated block before full-script execution.
3. **Apply fix in file only after eval passes:** If eval fails, iterate on snippet; do not repeatedly run full scripts while syntax is unresolved.
4. **Validate script with the `test-runner` first before full run:** Run your script actions with a test script using the exports from `bin/test-runner.sesi`.
5. **Run full script after validation:** Execute `npm run sesi <file>.sesi` only once the isolated logic is valid.
6. **NEVER EDIT ANY .SESI FILES IN THE TERMINAL (ABSOLUTE RULE):**
   - Do NOT run `sed`, `awk`, `perl`, or any other shell text-processing tools on `.sesi` files.
   - Do NOT use `npm run eval` to modify files; it is only for syntax validation.
   - Do NOT use Bash/Shell scripting to rewrite or patch Sesi source code.

**Automated Refactoring & Codemods (MANDATORY):**

- If you need to automate file edits, mass refactoring, or search-and-replace tasks across the workspace, you MUST utilize the helpers/ scripts. These are designed SPECIFICALLY for edits within this workspace.
- Do NOT write Python scripts, Node.js scripts, or Bash/Shell scripts for workspace file manipulations. Always let Sesi do its job.
  **Why:** Sesi syntax is sensitive to whitespace, newlines, and brace positioning. Terminal-based string replacement will invariably break code.

7. **Emphasize Native Verification Commands:** Prior to saving or running full Sesi scripts, proactively use inline evaluation (`npm run eval "sesi code"` or `node node_modules/@misterscan/sesi/bin/sesi.js -e "..."`) to check and verify syntax and runtime behaviors instantly. It keeps execution cycles fast and deterministic.

Sesi is **NOT** the following coding languages, therefore **NEVER UTILIZE THE SAME SYNTAX OR FORMATTING UNDER ANY CIRCUMSTANCES WHATSOEVER!!!!!**

- **NOT** An "AI Wrapper"
- **NOT** A "LLM Framework"
- **NOT** An "AI-Native Programming Language"
- **NOT** Python
- **NOT** Rust
- **NOT** Typescript
- **NOT** YAML
- **NOT** BAML
- **NOT** Go
- **NOT** C++
- **NOT** C
- **NOT** Java
- **NOT** C#
- **NOT** Javascript
- **NOT** Bash
- **NOT** Shell
- **NOT** Ruby
- **NOT** PHP
- **NOT** Swift
- **NOT** Julia
- **NOT** Scala
- **NOT** Any other programming language or scripting language.

## Mandatory Syntax Rules & Quirks

- **Block Termination:** Closing braces `}` for blocks (if, while, try, model) no longer strictly require a following newline or semicolon. Condensed one-liners like `while x {x = x + 1}` are valid.
- **Prompts & Prints:** Inside `prompt` blocks, anonymous model blocks, and `print` statements, literal strings and variables are placed sequentially naturally (e.g., `print "User:" name`). It is highly preferred to **AVOID** use of the `+` operator in these contexts, regardless of its backwards-compatibility.
- **No Raw Newlines in Prompt Blocks:** Raw newlines (e.g. formatting layout carriage returns) are strictly forbidden outside of string literals inside prompt blocks `{}` (e.g., between `{` and the first string, or between elements). These will be parsed as statement separators and trigger syntax errors. Write prompt blocks inline on a single line (e.g., `{"prompt text " variable}`), or place newlines inside the double quotes of a multiline string. To include actual newlines in the **output**, place them literally inside the string quotes:

```sesi
prompt report {"Student: " name "
Score: " score "
Grade: A"}
```

The newline is a real line break _inside the string literal_ — not `\n`, not any escape sequence.

- **Structured Output Schemas:** Keys in schemas MUST be unquoted identifiers (e.g., `{key: string}` instead of `{"key": string}`). This is a known deviation from standard JSON objects in the Sesi parser.
- **Object Literals:** Conversely, standard object literals `{}` DO require strictly quoted string keys (e.g., `{"name": "Alice"}`).
- **JSON Serialization:** Use `to_json(object)` for valid JSON output. Avoid `stringify(object)` for JSON.
- **Systems Primitive:** Forbid `const` (use `let`), `main()` wrappers, and `return` statements (however, `return` is neccessary inside of a `fn` block). Focus on side-effects and top-level execution.
- **Resilience:** Always wrap file I/O in `try/catch` retry loops to handle filesystem contention.

For all quirks and specific syntaxing, visit GUIDE.md/, dist/, node_modules/@misterscan/sesi/docs/BUILTINS.md, node_modules/@misterscan/sesi/docs/WRITING_SCRIPTS.md, and node_modules/@misterscan/sesi/getting-started/ to verify against the actual engine specifications. Do not rely on training data or outdated documentation for syntax rules, always verify against the source.

## IGNORE THESE FILES

- `*.txt`
- `*.log`
- `.sesi_cache.json`'}

if safe_write(rulesDir + "/sesi-must-read.md", sesiMustReadRules) {
  print "✓ Generated .agents/rules/sesi-must-read.md"
} else {
  print "⚠️ Failed to generate .agents/rules/sesi-must-read.md"
}

// Generate .agents/workflows/create-sesi-script.md
prompt createSesiScript {'---
description: Intent-based development workflow for generating concise, syntax-accurate Sesi scripts using integrated web research and verified implementation patterns.
---

## Operational Directives

1. **Let Sesi Do Its Job**: A Sesi builder script makes the system perfectly repeatable, infinitely scalable, and trivial to refactor. In this repository, the Sesi script is the core product; the end file(s) are merely the byproduct for post edits and making sure our scripts are behaving as anticipated.
2. **Script Creation:** Your primary task is to generate scripts in Sesi.
3. **Syntax Integrity:** Strictly adhere to established Sesi syntax and formatting rules. Never fabricate or hallucinate rules. If a pattern is not verified within Sesi, do not use it.
4. **Language and Perspective:** Maintain a grounded, practical perspective. Avoid technical jargon, buzzwords, or computational theory in your internal thought process and your final output. Focus on what the user has requested at hand. Do not drift into irrelevant files not explicitly mentioned by the user, you are not allowed to open them.
5. **Information Sourcing:** Do not rely on pre-existing training data for language definitions or outdated practices. Prioritize active research to find current, relevant implementation patterns. If a method or approach is flagged as outdated, discard it immediately.
6. **Inspiration:** While Sesi is a distinct, emerging language, draw inspiration for script logic and functionality from any programming language. Ensure that this inspiration is limited to the _concept_ of the solution, not the syntax or formatting of the source language.
7. **Cautious Integration:** Do NOT use model(), image(), or workflow(). The user is the only one with permission to use these functions. Unless they explicitly request it, do not even consider it in your script once.
8. **Core Philosophy:** Sesi scripts must be concise, legible, and intent-based. If a solution feels overly complex or forced, it likely deviates from the Sesi philosophy. Keep the implementation direct.
9. **Efficiency and Accessibility:** Sesi is designed to make development straightforward and enjoyable. Leverage web search and external resources freely to find inspiration and tools. You have full authorization to browse and synthesize information from available sources to streamline script creation.

## Mandatory Syntax Rules & Quirks

- **Block Termination:** Closing braces `}` for blocks (if, while, try, model) no longer strictly require a following newline or semicolon. Condensed one-liners like `while x {x = x + 1}` are valid.
- **Prompts & Prints:** Inside `prompt` blocks, anonymous model blocks, and `print` statements, literal strings and variables are placed sequentially naturally (e.g., `print "User:" name`). It is highly preferred to **AVOID** use of the `+` operator in these contexts, regardless of its backwards-compatibility.
- **No Raw Newlines in Prompt Blocks:** Raw newlines (e.g. formatting layout carriage returns) are strictly forbidden outside of string literals inside prompt blocks `{}` (e.g., between `{` and the first string, or between elements). These will be parsed as statement separators and trigger syntax errors. Write prompt blocks inline on a single line (e.g., `{"prompt text " variable}`), or place newlines inside the double quotes of a multiline string. To include actual newlines in the **output**, place them literally inside the string quotes:

```sesi
prompt report {"Student: " name "
Score: " score "
Grade: A"}
```

The newline is a real line break _inside the string literal_ — not `\n`, not any escape sequence.

- **Structured Output Schemas:** Keys in schemas MUST be unquoted identifiers (e.g., `{key: string}` instead of `{"key": string}`). This is a known deviation from standard JSON objects in the Sesi parser.
- **Object Literals:** Conversely, standard object literals `{}` DO require strictly quoted string keys (e.g., `{"name": "Alice"}`).
- **JSON Serialization:** Use `to_json(object)` for valid JSON output. Avoid `stringify(object)` for JSON.
- **Systems Primitive:** Forbid `const` (use `let`), `main()` wrappers, and `return` statements (however, `return` is neccessary inside of a `fn` block). Focus on side-effects and top-level execution.
- **Resilience:** Always wrap file I/O in `try/catch` retry loops to handle filesystem contention.

## Agent Debug Protocol (MANDATORY)

When AI agents write or edit `.sesi` scripts, they must use this debugging loop:

1. **Draft in file, isolate risky snippet:** Identify the smallest parser/runtime-risky block (prompt block, model call, object schema, loop, etc.).
2. **Validate snippet with eval mode first:** Run `npm run eval "sesi code"` to test the isolated block before full-script execution.
3. **Apply fix in file only after eval passes:** If eval fails, iterate on snippet; do not repeatedly run full scripts while syntax is unresolved.
4. **Validate script with the `test-runner` first before full run:** Run your script actions with a test script using the exports from `bin/test-runner.sesi`. Refer to `main/tests/verify_db.sesi` for an example.
5. **Run full script after validation:** Execute `npm run sesi <file>.sesi` only once the isolated logic is valid.
6. **Use file-aware help when blocked:** Run `npm run help <file>.sesi "<question>"` to get context-grounded help tied to the active script.
7. **NEVER EDIT ANY .SESI FILES IN THE TERMINAL (ABSOLUTE RULE):**
   - Do NOT run `sed`, `awk`, `perl`, or any other shell text-processing tools on `.sesi` files.
   - Do NOT use `npm run eval` to modify files; it is only for syntax validation.
   - Do NOT use Bash/Shell scripting to rewrite or patch Sesi source code.

**Automated Refactoring & Codemods (MANDATORY):**

- If you need to automate file edits, mass refactoring, or search-and-replace tasks across the workspace, you MUST utilize the helpers/ scripts. These are designed SPECIFICALLY for edits within this workspace.
- Do NOT write Python scripts, Node.js scripts, or Bash/Shell scripts for workspace file manipulations. Always let Sesi do its job.
  **Why:** Sesi syntax is sensitive to whitespace, newlines, and brace positioning. Terminal-based string replacement will invariably break code.

8. **Emphasize Native Verification Commands:** Prior to saving or running full Sesi scripts, proactively use inline evaluation (`npm run eval ""sesi code""` or `node node_modules/@misterscan/sesi/bin/sesi.js -e ""...""`) to check and verify syntax and runtime behaviors instantly. It keeps execution cycles fast and deterministic.'}

if safe_write(workflowsDir + "/create-sesi-script.md", createSesiScript) {
  print "✓ Generated .agents/workflows/create-sesi-script.md"
} else {
  print "⚠️ Failed to generate .agents/workflows/create-sesi-script.md"
}

