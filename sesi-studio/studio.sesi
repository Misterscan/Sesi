let pending_file_to_open = ""

fn handle_http(req) {
  let path = req.path
  let method = req.method
  
  if path == "/api/open" {
    let file = req.query["file"]
    if file != null && file != "" {
      pending_file_to_open = file
      return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"status": "success"}}
    }
    return {"status": 400, "body": "Missing file parameter"}
  }

  if path == "/api/open-pending" {
    let result = pending_file_to_open
    pending_file_to_open = ""
    if result != "" {
      return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"filePath": result}}
    }
    return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"filePath": null}}
  }

  if path == "/api/workspace" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let new_root = body_obj["path"]
      if new_root != null && new_root != "" {
        PROJECT_ROOT = new_root
        print "Sesi Studio: Workspace changed to " + PROJECT_ROOT
        return {"status": 200, "body": {"success": true}}
      }
      return {"status": 400, "body": {"error": "Missing path parameter"}}
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }
  
  if path == "/" {
    try {
      let content = read_file("sesi-studio/build/index.min.html")
      return {"status": 200, "headers": {"Content-Type": "text/html"}, "body": content}
    } catch (e) {
      return {"status": 500, "body": "Failed to load index.html"}
    }
  }

  if path == "/img/favicon.png" || path == "/favicon.ico" {
    return {"status": 200, "headers": {"Content-Type": "image/png"}, "body": favicon}
  }

  if path == "/api/files" {
    try {
      let query_path = req.query["path"]
      if query_path == "" || query_path == null {
        query_path = "."
      }
      let items = list_dir(query_path)
      let result = []
      for item in items {
        if item != ".git" && item != "node_modules" && item != ".DS_Store" {
          let isDir = false
          let item_path = item
          if query_path != "." && query_path != "" {
            item_path = query_path + "/" + item
          }
          try {
            let tmp = list_dir(item_path)
            if tmp != null {
              isDir = true
            }
          } catch (err) {}
          push(result, {"name": item, "isDir": isDir, "path": item_path})
        }
      }
      return {"status": 200, "body": result}
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }

  if path == "/api/file" && method == "GET" {
    try {
      let query_path = req.query["path"]
      let content = read_file(query_path)
      return {"status": 200, "body": {"content": content, "path": query_path}}
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }

  if path == "/api/file" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      write_file(body_obj["path"], body_obj["content"])
      return {"status": 200, "body": {"success": true}}
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }

  if path == "/api/chat" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let q = body_obj["query"]
      let sessionId = body_obj["sessionId"]
      let history_str = ""
      let chat_doc = null
      let existing = []
      
      if sessionId != null && conversations_col != null {
        try {
          existing = conversations_col.find({"session_id": sessionId})
        } catch (db_err) {}
      }
      
      if len(existing) > 0 {
        chat_doc = existing[0]
        let messages = chat_doc["messages"]
        if messages != null {
          for msg in messages {
            let role = "User"
            if msg["isUser"] == false {
              role = "Co-Pilot"
            }
            history_str = history_str + role + ": " + msg["text"] + "\n"
          }
        }
      } else {
        chat_doc = {
          "session_id": sessionId,
          "messages": [],
          "metadata": {"title": "New Chat"}
        }
      }
      
      let user_msg = {"text": q, "isUser": true}
      push(chat_doc["messages"], user_msg)
      
      let system_prompt = copilotMemory
      if body_obj["filePath"] != null {
        let active_file = body_obj["filePath"]
        let active_content = body_obj["fileContent"]
        system_prompt = system_prompt + "\n\n[Active File: " + active_file + "\n```\n" + active_content + "\n```]"
      }
      system_prompt = system_prompt + "\n\n====IGNORE ME====\n" + timestamp + "\n====IGNORE ME===="

      system_prompt = system_prompt + "

You have access to the following tools to assist the user:

- `list_directory`: Lists files in a directory.
  Arguments JSON schema: {\"path\": string} (optional, defaults to \".\")
- `read_file`: Reads the full content of a file.
  Arguments JSON schema: {\"path\": string}
- `write_file`: Writes content to a file, creating or overwriting it.
  Arguments JSON schema: {\"path\": string, \"content\": string}
- `search_google`: Searches the internet for information using search engine.
  Arguments JSON schema: {\"query\": string}
- `run_helper_script`: Runs a specific Sesi helper script from the `helpers/` directory (e.g. line-swap.sesi, dependency-graph.sesi, css-flatten.sesi, version-bump.sesi, text-search.sesi, html-minify.sesi, agent-file-ops.sesi, etc.). Use this for mass/automated code refactoring and edits instead of other generic tools.
  Arguments JSON schema: {\"script_name\": string, \"args_str\": string}
- `eval_sesi_code`: Evaluates inline Sesi code. Use this to execute code snippets, verify Sesi script behavior, and call Sesi's essential built-in functions.
  Arguments JSON schema: {\"code\": string}
- `call_image_subagent`: Delegates image asset generation to a dedicated prompt-refinement subagent. Generates the image via Sesi's native image engine, saves the file to disk, and returns the result path.
  Arguments JSON schema: {\"prompt\": string, \"aspect_ratio\": string (e.g. \"1:1\", \"16:9\", \"4:3\", \"3:2\", \"9:16\", defaults to \"1:1\"), \"output_path\": string (defaults to \"generated_image.png\")}

Essential Sesi Built-in Functions Reference:
- I/O: `print(...args)`
- Type conversions: `str(val)`, `num(val)`, `bool(val)`, `to_json(val)`, `from_json(str)`
- Collections: `len(col)`, `keys(obj)`, `values(obj)`, `push(arr, val)`, `pop(arr)`, `join(arr, sep)`, `split(str, sep)`, `slice(str, start, end)`, `locate(str, target)`, `contains(str, target)`
- Filesystem: `read_file(path)`, `write_file(path, content)`, `write_image(path, base64_data_url_or_b64str)`, `make_dir(path)`, `list_dir(path)`
- Encryption & DB: `db_open(path, pwd)` (returns Database object with collections/insert/find/update/delete)
- Browser Automation: `launch(opts)`, `newPage()`, `goto(url)`, `click(sel)`, `fill(sel, val)`, `screenshot(path)`

If the user request requires examining files, writing/testing scripts, performing automated edits, or generating visual assets/images, use the appropriate tools.
"

      let copilot_tools = {
        "read_file": agent_read_file,
        "write_file": agent_write_file,
        "list_directory": agent_list_directory,
        "search_google": agent_search_google,
        "run_helper_script": agent_run_helper_script,
        "eval_sesi_code": agent_eval_sesi_code,
        "call_image_subagent": agent_generate_image
      }

      if body_obj["browserAccess"] == true {
        copilot_tools["browser_goto"] = agent_browser_goto
        copilot_tools["browser_click"] = agent_browser_click
        copilot_tools["browser_fill"] = agent_browser_fill
        copilot_tools["browser_screenshot"] = agent_browser_screenshot
        copilot_tools["browser_get_content"] = agent_browser_get_content
        copilot_tools["browser_close"] = agent_browser_close

        system_prompt = system_prompt + "

You have browser access enabled. Use these tools for visual analysis and verification (such as checking layouts, UI styling, rendered graphics, or media) whenever direct visual inspection is needed to evaluate the application's state:

- `browser_goto`: Navigates to a URL. Arguments JSON schema: {\"url\": string}
- `browser_click`: Clicks an element. Arguments JSON schema: {\"selector\": string}
- `browser_fill`: Fills an input value. Arguments JSON schema: {\"selector\": string, \"value\": string}
- `browser_screenshot`: Captures screenshot. Arguments JSON schema: {\"path\": string} (optional)
- `browser_get_content`: Gets the visible text content of the page. Arguments: {}
- `browser_close`: Closes the active browser. Arguments: {}
"
      }

      let agent = Agent.create({
        "model": "chat",
        "system": system_prompt,
        "thinkingLevel": "low",
        "cache": false,
        "max_tokens": 4096,
        "tools": copilot_tools
      })

      if len(existing) > 0 {
        let messages = existing[0]["messages"]
        if messages != null {
          for msg in messages {
            let role = "user"
            if msg["isUser"] == false {
              role = "assistant"
            }
            push(agent["history"], {"role": role, "text": msg["text"]})
          }
        }
      }

      let res = Agent.chat(agent, q)
      
      let assistant_msg = {"text": res, "isUser": false}
      push(chat_doc["messages"], assistant_msg)
      
      if conversations_col != null && sessionId != null {
        try {
          if len(existing) > 0 {
            conversations_col.update({"session_id": sessionId}, chat_doc)
          } else {
            conversations_col.insert(chat_doc)
          }
        } catch (db_save_err) {}
      }
      
      return {"status": 200, "body": {"response": res}}
    } catch (e) {
      return {"status": 200, "body": {"response": "⚠️ Co-pilot error: " + str(e)}}
    }
  }

  if path == "/api/chats" && method == "GET" {
    try {
      let chats = []
      if conversations_col != null {
        let docs = conversations_col.find(null)
        for doc in docs {
          let chat_obj = {
            "id": doc["session_id"],
            "title": doc["metadata"]["title"],
            "messages": doc["messages"]
          }
          push(chats, chat_obj)
        }
      }
      return {
        "status": 200,
        "headers": {"Content-Type": "application/json"},
        "body": {"chats": chats}
      }
    } catch (e) {
      return {
        "status": 500,
        "headers": {"Content-Type": "application/json"},
        "body": {"error": str(e)}
      }
    }
  }

  if path == "/api/chats/save" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let new_chats = body_obj["chats"]
      
      if conversations_col != null && new_chats != null {
        conversations_col.delete({})
        for chat in new_chats {
          let chat_doc = {
            "session_id": chat["id"],
            "messages": chat["messages"],
            "metadata": {
              "title": chat["title"]
            }
          }
          conversations_col.insert(chat_doc)
        }
      }
      return {
        "status": 200,
        "headers": {"Content-Type": "application/json"},
        "body": {"success": true}
      }
    } catch (e) {
      return {
        "status": 500,
        "headers": {"Content-Type": "application/json"},
        "body": {"error": str(e)}
      }
    }
  }

  if path == "/api/autocomplete" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let prefix = body_obj["prefix"]
      let suffix = body_obj["suffix"]
      let file_path = body_obj["filePath"]
      if file_path == null {
        file_path = "unsaved.sesi"
      }
      prompt completionPrompt { "You are a professional software engineer. Your job is to act as an inline code completion engine (like GitHub Copilot) for the Sesi programming language.\n\nHere is the context of the active file:\nFile name: " file_path "\n\nPrefix (code before cursor):\n" prefix "\n\nSuffix (code after cursor):\n" suffix "\n\nTask: Complete the code exactly from where the cursor left off.\nRules:\n- Respond ONLY with the raw code completion that immediately continues the prefix.\n- Do NOT wrap your response in markdown code blocks.\n- Do NOT include the prefix or suffix in your response.\n- Do NOT provide explanations, commentary, or comments.\n- Complete only the immediate logical block, line, or expression.\n- If no completion makes sense, return absolutely nothing." }
      let agent = Agent.create({
        "model": "copilot",
        "system": copilotMemory,
        "thinkingLevel": "low",
        "max_tokens": 300
      })
      let res = Agent.run(agent, completionPrompt)
      return {"status": 200, "body": {"suggestion": res}}
    } catch (e) {
      print "Autocomplete Error: " str(e)
      return {"status": 200, "body": {"suggestion": ""}}
    }
  }

  if path == "/api/syntax" {
    try {
      // Use a brief Node script to leverage RegEx for extracting TextMate syntax safely
      let script = "const fs=require('fs');const t=JSON.parse(fs.readFileSync('editors/vscode/syntaxes/sesi.tmLanguage.json'));const e=fs.readFileSync('editors/vscode/extension.js','utf8');const x=p=>{let m=[];if(p)p.forEach(r=>{if(r.match)m=m.concat(r.match.replace(/\\\\\\\\b/g,'').replace(/\\\\b/g,'').replace(/^\\(\\?\\:/,'(').replace(/^\\(/,'').replace(/\\)$/,'').split('|'))});return m};let dm=e.match(/const docs = ({[\\s\\S]*?});\\s*(?:let|const) hoverProvider/);console.log(JSON['stringify']({keywords:x(t.repository?.keywords?.patterns),typeKeywords:x(t.repository?.types?.patterns),constants:x(t.repository?.constants?.patterns),builtins:x(t.repository?.builtins?.patterns),docs:dm?eval('('+dm[1]+')'):{}}));"
      let result = exec_node("-e \"" + script + "\"")
      return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": result}
    } catch (e) {
      return {"status": 500, "body": {"error": "Failed to load syntax config"}}
    }
  }

  if path == "/api/analyzer" {
    try {
      let ext_content = read_file("editors/vscode/extension.js")
      let prefix = "(function(require, module, process){\n"
      let exports = "\nwindow.sesiTokenizer = tokenize;\nwindow.sesiFindDecls = findDeclarationsAndReferences;\nwindow.sesiAnalyzeScope = analyzeScope;\nwindow.sesiScope = Scope;\nwindow.sesiIsConfigBlockKey = isConfigBlockKey;"
      let suffix = "\n})(function(name) { if (name === 'vscode') { return { Range: class { constructor(s, e) { this.start = s; this.end = e; } }, Position: class { constructor(l, c) { this.line = l; this.character = c; } }, Diagnostic: class { constructor(r, m, s) { this.range = r; this.message = m; this.severity = s; } }, DiagnosticSeverity: { Error: 0, Warning: 1, Information: 2, Hint: 3 } }; } if (name === 'path') { return { dirname: (p) => p.split('/').slice(0, -1).join('/') || '.', join: (...args) => args.filter(Boolean).join('/').replace(/\\/+/g, '/'), resolve: (...args) => args.filter(Boolean).join('/').replace(/\\/+/g, '/') }; } if (name === 'fs') { return { existsSync: () => false, readFileSync: () => '' }; } if (name === 'os') { return { homedir: () => '' }; } return {}; }, { exports: {} }, { cwd: () => '', env: {}, platform: 'darwin' });"
      ext_content = prefix + ext_content + exports + suffix
      return {"status": 200, "headers": {"Content-Type": "application/javascript"}, "body": ext_content}
    } catch (e) {
      return {"status": 500, "body": {"error": "Failed to load analyzer: " + str(e)}}
    }
  }

  if path == "/api/validate" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let content = body_obj["content"]
      let temp_name = ".sesi_cache_temp_" + str(time()) + ".sesi"
      write_file(temp_name, content)
      
      let check_result = ""
      let success = true
      try {
        check_result = exec_node("\"" + SESI_ROOT + "/bin/sesi.js\" -c \"" + temp_name + "\"")
      } catch (e) {
        check_result = str(e)
        success = false
      }
      
      try {
        exec("rm " + temp_name)
      } catch (e_rm) {
        try {
          exec("del " + temp_name)
        } catch (e_del) {}
      }
      
      return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"success": success, "output": check_result}}
    } catch (e) {
      return {"status": 500, "body": {"error": "Failed to validate: " + str(e)}}
    }
  }

  if path == "/api/ast" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let content = body_obj["content"]
      let temp_name = ".sesi_ast_temp_" + str(time()) + ".sesi"
      let js_temp_name = ".sesi_ast_runner_" + str(time()) + ".js"
      
      write_file(temp_name, content)
      
      let js_code = "const {Lexer,Parser}=require('./dist/index.js'); const fs=require('fs'); try { const code=fs.readFileSync('" + temp_name + "','utf8'); const tokens=new Lexer(code).scanTokens(); const parser=new Parser(tokens); const prog=parser.parse(); if(parser.errors.length > 0){ console.error(parser.errors.join('\\n')); process.exit(1); } console.log(JSON.stringify(prog)); } catch(e) { console.error(e.message); process.exit(1); }"
      write_file(js_temp_name, js_code)
      
      let parse_result = ""
      let success = true
      try {
        parse_result = exec_node(js_temp_name)
      } catch (e) {
        parse_result = str(e)
        success = false
      }
      
      try {
        exec("rm " + temp_name)
      } catch (e_rm) {
        try {
          exec("del " + temp_name)
        } catch (e_del) {}
      }
      
      try {
        exec("rm " + js_temp_name)
      } catch (e_rm_js) {
        try {
          exec("del " + js_temp_name)
        } catch (e_del_js) {}
      }
      
      if success {
        return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"success": true, "ast": from_json(parse_result)}}
      } else {
        return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"success": false, "error": parse_result}}
      }
    } catch (e) {
      return {"status": 500, "body": {"error": "Failed to parse AST: " + str(e)}}
    }
  }

  if path == "/api/agent/tool" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let tool_name = body_obj["tool_name"]
      let tool_args = body_obj["tool_args"]
      
      let tool_fn = global_tools[tool_name]
      if tool_fn == null {
        return {"status": 400, "headers": {"Content-Type": "application/json"}, "body": {"success": false, "error": "Tool " + tool_name + " not found"}}
      }
      
      let res = tool_fn(tool_args)
      return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"success": true, "result": res}}
    } catch(e) {
      return {"status": 500, "headers": {"Content-Type": "application/json"}, "body": {"success": false, "error": "Tool execution failed: " + str(e)}}
    }
  }

  if path == "/api/profile" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let content = body_obj["content"]
      let temp_name = ".sesi_profile_temp_" + str(time()) + ".sesi"
      write_file(temp_name, content)
      let output_str = ""
      let success = true
      try {
        let cmd = "SESI_DEBUG=1 node \"" + SESI_ROOT + "/bin/sesi.js\" -l \"" + temp_name + "\""
        if IS_WINDOWS {
          cmd = "set SESI_DEBUG=1 && cmd.exe /c node \"" + SESI_ROOT + "/bin/sesi.js\" -l \"" + temp_name + "\""
        }
        output_str = exec_in_project(cmd)
      } catch (e) {
        output_str = str(e)
        success = false
      }
      try {
        exec("rm " + temp_name)
      } catch (e_rm) {
        try {
          exec("del " + temp_name)
        } catch (e_del) {}
      }
      
      return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"success": success, "output": output_str}}
    } catch (e) {
      return {"status": 500, "body": {"error": "Failed to profile script: " + str(e)}}
    }
  }


  if path == "/api/extensions" {
    try {
      make_dir("sesi-studio/extensions")
      make_dir("sesi-studio/extensions/themes")
      let items = list_dir("sesi-studio/extensions")
      let theme_items = list_dir("sesi-studio/extensions/themes")
      let result = []
      
      fn get_metadata(base_path, file_name) {
        let full_path = base_path + "/" + file_name
        try {
          /* 
            Use Node to safely extract the first comment block as JSON
            Using indexOf to avoid complex Regex escaping issues in Sesi/Shell strings 
          */
          let script = "const fs=require('fs');const c=fs.readFileSync('" + full_path + "','utf8');const s=c.indexOf('/*');const e=c.indexOf('*/');if(s===-1||e===-1)process.stdout.write('null');else process.stdout.write(c.slice(s+2,e).trim())"
          let json_str = exec_node('-e "' + script + '"')
          if json_str == "null" || json_str == "" {
            return null
          }
          return from_json(json_str)
        } catch (e) {
          return null
        }
      }

      // Top level extensions
      for item in items {
        let file_parts = split(item, ".")
        let ext = file_parts[len(file_parts) - 1]
        if ext == "js" || ext == "css" {
          let meta = get_metadata("sesi-studio/extensions", item)
          let entry = {"name": item, "type": ext}
          if meta != null {
            entry["displayName"] = meta["name"]
            entry["version"] = meta["version"]
            entry["description"] = meta["description"]
            entry["author"] = meta["author"]
            entry["commands"] = meta["commands"]
            entry["icon"] = meta["icon"]
            entry["license"] = meta["license"]
          }
          push(result, entry)
        }
      }
      
      // Themes subfolder
      for item in theme_items {
        let file_parts = split(item, ".")
        let ext = file_parts[len(file_parts) - 1]
        if ext == "css" {
          let meta = get_metadata("sesi-studio/extensions/themes", item)
          let entry = {"name": "themes/" + item, "type": ext}
          if meta != null {
            entry["displayName"] = meta["name"]
            entry["version"] = meta["version"]
            entry["description"] = meta["description"]
            entry["author"] = meta["author"]
            entry["commands"] = meta["commands"]
            entry["icon"] = meta["icon"]
            entry["license"] = meta["license"]
          }
          push(result, entry)
        }
      }
      
      return {"status": 200, "body": result}
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }

  if path == "/api/install-theme" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let content = ""
      if body_obj["filePath"] != null && body_obj["filePath"] != "" {
        content = read_file(body_obj["filePath"])
      } else if body_obj["themeContent"] != null && body_obj["themeContent"] != "" {
        content = body_obj["themeContent"]
      } else {
        return {"status": 400, "body": {"error": "Missing 'filePath' or 'themeContent' parameter."}}
      }
      
      let bundle = from_json(content)
      if bundle == null {
        return {"status": 400, "body": {"error": "Invalid theme bundle JSON."}}
      }
      
      let meta = bundle["metadata"]
      let css = bundle["css"]
      if meta == null || css == null {
        return {"status": 400, "body": {"error": "Theme bundle is missing 'metadata' or 'css' payload."}}
      }
      
      let theme_name = meta["name"]
      if theme_name == null || theme_name == "" {
        return {"status": 400, "body": {"error": "Theme manifest is missing a name."}}
      }
      
      let safe_name = join(split(theme_name, " "), "-")
      safe_name = join(split(safe_name, "/"), "-")
      
      make_dir("sesi-studio/extensions")
      make_dir("sesi-studio/extensions/themes")
      
      let out_path = "sesi-studio/extensions/themes/" + safe_name + ".css"
      let css_file_content = "/*\n" + to_json(meta) + "\n*/\n" + css
      
      write_file(out_path, css_file_content)
      return {"status": 200, "body": {"success": true, "themeName": theme_name, "installedPath": out_path}}
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }

  if path == "/api/install-extension" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let content = ""
      if body_obj["filePath"] != null && body_obj["filePath"] != "" {
        content = read_file(body_obj["filePath"])
      } else if body_obj["extensionContent"] != null && body_obj["extensionContent"] != "" {
        content = body_obj["extensionContent"]
      } else {
        return {"status": 400, "body": {"error": "Missing 'filePath' or 'extensionContent' parameter."}}
      }
      
      let bundle = from_json(content)
      if bundle == null {
        return {"status": 400, "body": {"error": "Invalid extension bundle JSON."}}
      }
      
      let meta = bundle["metadata"]
      let js = bundle["js"]
      if meta == null || js == null {
        return {"status": 400, "body": {"error": "Extension bundle is missing 'metadata' or 'js' payload."}}
      }
      
      let ext_name = meta["name"]
      if ext_name == null || ext_name == "" {
        return {"status": 400, "body": {"error": "Extension manifest is missing a name."}}
      }
      
      let safe_name = join(split(ext_name, " "), "-")
      safe_name = join(split(safe_name, "/"), "-")
      
      make_dir("sesi-studio/extensions")
      
      let out_path = "sesi-studio/extensions/" + safe_name + ".js"
      let js_file_content = "/*\n" + to_json(meta) + "\n*/\n" + js
      
      write_file(out_path, js_file_content)
      return {"status": 200, "body": {"success": true, "extensionName": ext_name, "installedPath": out_path}}
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }

  if path == "/marketplace.json" {
    try {
      let content = read_file("sesi-studio/marketplace.json")
      return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": content}
    } catch (e) {
      return {"status": 404, "body": "Marketplace catalog not found"}
    }
  }

  let rel_parts = split(path, "/releases/")
  if len(rel_parts) == 2 && rel_parts[0] == "" {
    let subpath = rel_parts[1]
    try {
      let content = read_file("sesi-studio/releases/" + subpath)
      let content_type = "application/json"
      return {"status": 200, "headers": {"Content-Type": content_type}, "body": content}
    } catch (e) {
      return {"status": 404, "body": "Release file not found"}
    }
  }

  if path == "/api/marketplace/list" && method == "GET" {
    try {
      let registry_url = req.query["registryUrl"]
      if registry_url == null || registry_url == "" {
        registry_url = "https://raw.githubusercontent.com/misterscan/sesi-marketplace/main/marketplace.json"
      }
      let catalog_str = web_get(registry_url)
      return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": catalog_str}
    } catch (e) {
      return {"status": 500, "body": {"error": "Failed to fetch marketplace: " + str(e)}}
    }
  }

  if path == "/api/marketplace/install" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let download_url = body_obj["downloadUrl"]
      let item_type = body_obj["type"]
      
      if download_url == null || download_url == "" {
        return {"status": 400, "body": {"error": "Missing downloadUrl parameter"}}
      }
      
      print "Marketplace: downloading " + download_url
      let bundle_content = web_get(download_url)
      let bundle = from_json(bundle_content)
      if bundle == null {
        return {"status": 400, "body": {"error": "Downloaded bundle is not valid JSON"}}
      }
      
      let meta = bundle["metadata"]
      if meta == null {
        return {"status": 400, "body": {"error": "Bundle metadata is missing"}}
      }
      let item_name = meta["name"]
      if item_name == null || item_name == "" {
        return {"status": 400, "body": {"error": "Bundle metadata name is missing"}}
      }
      
      let safe_name = join(split(item_name, " "), "-")
      safe_name = join(split(safe_name, "/"), "-")
      
      if item_type == "theme" {
        let css = bundle["css"]
        if css == null {
          return {"status": 400, "body": {"error": "Theme bundle is missing 'css' payload"}}
        }
        make_dir("sesi-studio/extensions/themes")
        let out_path = "sesi-studio/extensions/themes/" + safe_name + ".css"
        let css_file_content = "/*\n" + to_json(meta) + "\n*/\n" + css
        write_file(out_path, css_file_content)
        return {"status": 200, "body": {"success": true, "name": item_name, "installedPath": out_path}}
      } else if item_type == "extension" {
        let js = bundle["js"]
        if js == null {
          return {"status": 400, "body": {"error": "Extension bundle is missing 'js' payload"}}
        }
        make_dir("sesi-studio/extensions")
        let out_path = "sesi-studio/extensions/" + safe_name + ".js"
        let js_file_content = "/*\n" + to_json(meta) + "\n*/\n" + js
        write_file(out_path, js_file_content)
        return {"status": 200, "body": {"success": true, "name": item_name, "installedPath": out_path}}
      } else {
        return {"status": 400, "body": {"error": "Invalid type parameter. Must be 'theme' or 'extension'."}}
      }
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }

  let nm_parts = split(path, "/node_modules/")
  if len(nm_parts) == 2 && nm_parts[0] == "" {
    let subpath = nm_parts[1]
    try {
      let content = read_file("sesi-studio/node_modules/" + subpath)
      let content_type = "text/plain"
      let file_parts = split(subpath, ".")
      let ext = file_parts[len(file_parts) - 1]
      if ext == "js" {
        content_type = "application/javascript"
      }
      if ext == "css" {
        content_type = "text/css"
      }
      return {"status": 200, "headers": {"Content-Type": content_type}, "body": content}
    } catch (e) {
      return {"status": 404, "body": "Module file not found: " + str(e)}
    }
  }

  let ext_parts = split(path, "/extensions/")
  if len(ext_parts) == 2 && ext_parts[0] == "" {
    let subpath = ext_parts[1]
    try {
      let content = read_file("sesi-studio/extensions/" + subpath)
      let content_type = "text/plain"
      let file_parts = split(subpath, ".")
      let ext = file_parts[len(file_parts) - 1]
      if ext == "js" {
        content_type = "application/javascript"
      }
      if ext == "css" {
        content_type = "text/css"
      }
      if ext == "svg" {
        content_type = "image/svg+xml"
      }
      if ext == "png" || ext == "jpg" || ext == "jpeg" {

        /* 
          Handle binary files by converting to base64 via node since read_file is utf-8
          We return the raw buffer as a response body - most Sesi web implementations 
          will handle a base64 string if we provide the right content type or we might need 
          to tell the client to decode it. For simplicity, let's assume we can serve text-based icons (SVG/Emoji)
          and for binary we'll rely on the static server in server.js if it exists. 
        */
        let script = "console.log(require('fs').readFileSync('sesi-studio/extensions/" + subpath + "').toString('base64'))"
        exec_node("-e \"" + script + "\"")
      }
      return {"status": 200, "headers": {"Content-Type": content_type}, "body": content}
    } catch (e) {
      return {"status": 404, "body": "Extension file not found"}
    }
  }

  if path == "/api/git" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let action = body_obj["action"]
      
      if action == "status" {
        let initialized = true
        let status_out = ""
        let branch_out = ""
        try {
          status_out = exec_in_project("git status --porcelain")
          branch_out = exec_in_project("git branch --show-current")
          branch_out = split(branch_out, "\r")[0]
          branch_out = split(branch_out, "\n")[0]
        } catch (e) {
          initialized = false
        }
        
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {
            "initialized": initialized,
            "status": status_out,
            "branch": branch_out
          }
        }
      }
      
      if action == "init" {
        let out = exec_in_project("git init")
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "output": out}
        }
      }
      
      if action == "add" {
        let file = body_obj["file"]
        let out = exec_in_project("git add \"" + file + "\"")
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "output": out}
        }
      }
      
      if action == "unstage" {
        let file = body_obj["file"]
        let out = exec_in_project("git restore --staged \"" + file + "\"")
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "output": out}
        }
      }
      
      if action == "discard" {
        let file = body_obj["file"]
        let out = exec_in_project("git restore \"" + file + "\"")
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "output": out}
        }
      }
      
      if action == "commit" {
        let msg = body_obj["message"]
        write_file("sesi-studio/.git-commit-msg.tmp", msg)
        let out = ""
        try {
          out = exec_in_project("git commit -F sesi-studio/.git-commit-msg.tmp")
          out = split(out, "\r")[0]
        } catch (e) {
          try {
            exec("rm sesi-studio/.git-commit-msg.tmp")
          } catch (e2) {}
          return {"status": 200, "headers": {"Content-Type": "application/json"}, "body": {"success": false, "error": str(e)}}
        }
        try {
          exec("rm sesi-studio/.git-commit-msg.tmp")
        } catch (e2) {}
        
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "output": out}
        }
      }
      
      if action == "push" {
        let out = exec_in_project("git push")
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "output": out}
        }
      }
      
      if action == "pull" {
        let out = exec_in_project("git pull")
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "output": out}
        }
      }
      
      if action == "diff" {
        let file = body_obj["file"]
        let original = ""
        let current = ""
        
        try {
          original = exec_in_project("git show HEAD:\"" + file + "\"")
        } catch (e) {
          original = ""
        }
        
        try {
          current = read_file(file)
        } catch (e) {
          current = ""
        }
        
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {
            "success": true,
            "original": original,
            "modified": current
          }
        }
      }

      if action == "log" {
        let log_out = ""
        try {
          log_out = exec_in_project("git log --oneline -n 15")
        } catch (e) {
          log_out = "No commits yet."
        }
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "log": log_out}
        }
      }

      if action == "generate_commit_msg" {
        let generated_msg = ""
        try {
          generated_msg = exec_in_project("node bin/sesi.js -l helpers/commit_message.sesi --staged")
          
          let lines = split(generated_msg, "\n")
          let filtered = []
          let i = 0
          while i < len(lines) {
            let line = lines[i]
            if !contains(line, "injected env") {
              push(filtered, line)
            }
            i = i + 1
          }
          generated_msg = trim(join(filtered, "\n"))
        } catch (e) {
          generated_msg = ""
        }
        
        if generated_msg == "" || contains(generated_msg, "No diff found") {
          return {
            "status": 200,
            "headers": {"Content-Type": "application/json"},
            "body": {
              "success": false,
              "error": "No staged changes detected. Please stage files first."
            }
          }
        }
        
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {
            "success": true,
            "message": generated_msg
          }
        }
      }
      
      return {"status": 400, "body": {"error": "Unknown git action"}}
    } catch (e) {
      return {"status": 500, "body": {"error": str(e)}}
    }
  }

  if path == "/api/db" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let action = body_obj["action"]
      let db_path = body_obj["dbPath"]
      let password = body_obj["password"]
      if password == "" {
        password = null
      }
      
      if action == "list_databases" {
        let items = list_dir(".")
        let dbs = []
        for item in items {
          let parts = split(item, ".")
          let ext = parts[len(parts) - 1]
          if ext == "db" || ext == "json" {
            if item != "package.json" && item != "package-lock.json" && item != "marketplace.json" {
              push(dbs, item)
            }
          }
        }
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"databases": dbs}
        }
      }

      if action == "get_schema" {
        if db_path == null || db_path == "" {
          return {
            "status": 400,
            "headers": {"Content-Type": "application/json"},
            "body": {"error": "Missing dbPath"}
          }
        }
        
        let cols = get_db_collections(db_path, password)
        let collections_list = []
        if cols != null {
          for col in cols {
            push(collections_list, {"name": col})
          }
        }
        
        let is_enc = false
        try {
          let content = read_file(db_path)
          let parts = split(content, ":")
          if len(parts) == 2 {
            is_enc = true
          }
        } catch (e) {}

        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {
            "encrypted": is_enc,
            "authenticated": (cols != null),
            "collections": collections_list
          }
        }
      }

      if action == "get_documents" {
        let col_name = body_obj["collection"]
        let query_str = body_obj["query"]
        let query = null
        if query_str != null && query_str != "" {
          try {
            query = from_json(query_str)
          } catch (e) {}
        }
        
        let db = db_open(db_path, password)
        let col = db.collection(col_name)
        let docs = col.find(query)
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"documents": docs}
        }
      }

      if action == "save_document" {
        let col_name = body_obj["collection"]
        let doc = body_obj["document"]
        let db = db_open(db_path, password)
        let col = db.collection(col_name)
        let saved = col.insert(doc)
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "document": saved}
        }
      }

      if action == "delete_document" {
        let col_name = body_obj["collection"]
        let doc_id = body_obj["documentId"]
        let db = db_open(db_path, password)
        let col = db.collection(col_name)
        let deleted = col.delete({"_id": doc_id})
        return {
          "status": 200,
          "headers": {"Content-Type": "application/json"},
          "body": {"success": true, "deletedCount": deleted}
        }
      }

      return {
        "status": 400,
        "headers": {"Content-Type": "application/json"},
        "body": {"error": "Unknown db action"}
      }
    } catch (e) {
      return {
        "status": 500,
        "headers": {"Content-Type": "application/json"},
        "body": {"error": str(e)}
      }
    }
  }

  if path == "/api/proxy" && method == "POST" {
    try {
      let body_obj = from_json(req.body)
      let req_url = body_obj["url"]
      let req_method = body_obj["method"]
      let req_headers = body_obj["headers"]
      let req_body = body_obj["body"]

      if req_headers == null {
        req_headers = {}
      }

      let res_body = ""
      if req_method == "GET" {
        res_body = web_get(req_url, req_headers)
      } else {
        res_body = web_send(req_url, req_body, req_headers)
      }

      return {
        "status": 200,
        "headers": {"Content-Type": "application/json"},
        "body": {
          "success": true,
          "response": res_body
        }
      }
    } catch (e) {
      return {
        "status": 500,
        "headers": {"Content-Type": "application/json"},
        "body": {
          "success": false,
          "error": str(e)
        }
      }
    }
  }

  return {"status": 404, "body": "Not Found"}
}

let term_buffer = ""

fn handle_ws(client, msg) {
  try {
    let parsed = from_json(msg)
    if parsed["type"] == "terminal_write" {
      let data_str = parsed["data"]
      client.send(to_json({"type": "output", "data": data_str}))
    } else if parsed["type"] == "ping" {
      client.send(to_json({"type": "pong"}))
    } else if parsed["type"] == "chat" {
      let q = parsed["query"]
      let sessionId = parsed["sessionId"]
      let active_file = parsed["filePath"]
      let active_content = parsed["fileContent"]
      let browserAccess = parsed["browserAccess"]

      let existing = []
      if sessionId != null && conversations_col != null {
        try {
          existing = conversations_col.find({"session_id": sessionId})
        } catch(db_err) {}
      }

      let chat_doc = null
      if len(existing) > 0 {
        chat_doc = existing[0]
      } else {
        chat_doc = {
          "session_id": sessionId,
          "messages": [],
          "metadata": {"title": "New Chat"}
        }
      }
      if chat_doc["messages"] == null {
        chat_doc["messages"] = []
      }

      let user_msg = {"text": q, "isUser": true}
      push(chat_doc["messages"], user_msg)

      let system_prompt = copilotMemory
      if active_file != null {
        system_prompt = system_prompt + "\n\n[Active File: " + active_file + "\n```\n" + active_content + "\n```]"
      }
      let timestamp = ""
      try {
        timestamp = Time.now().format()
      } catch (err_t) {}
      system_prompt = system_prompt + "\n\n====IGNORE ME====\n" + timestamp + "\n====IGNORE ME===="

      system_prompt = system_prompt + "

You have access to the following tools to assist the user:

- `list_directory`: Lists files in a directory.
  Arguments JSON schema: {\"path\": string} (optional, defaults to \".\")
- `read_file`: Reads the full content of a file.
  Arguments JSON schema: {\"path\": string}
- `write_file`: Writes content to a file, creating or overwriting it.
  Arguments JSON schema: {\"path\": string, \"content\": string}
- `run_helper_script`: Runs a specific Sesi helper script from the `helpers/` directory (e.g. line-swap.sesi, dependency-graph.sesi, css-flatten.sesi, version-bump.sesi, text-search.sesi, html-minify.sesi, agent-file-ops.sesi, etc.). Use this for mass/automated code refactoring and edits instead of other generic tools.
  Arguments JSON schema: {\"script_name\": string, \"args_str\": string}
- `eval_sesi_code`: Evaluates inline Sesi code. Use this to execute code snippets, verify Sesi script behavior, and call Sesi's essential built-in functions.
  Arguments JSON schema: {\"code\": string}

- `call_image_subagent`: Delegates image asset generation to a dedicated prompt-refinement subagent. Generates the image via Sesi's native image engine, saves the file to disk, and returns the result path.
  Arguments JSON schema: {\"prompt\": string, \"aspect_ratio\": string (e.g. \"1:1\", \"16:9\", \"4:3\", \"3:2\", \"9:16\", defaults to \"1:1\"), \"output_path\": string (defaults to \"generated_image.png\")}

Essential Sesi Built-in Functions Reference:
- I/O: `print(...args)`
- Type conversions: `str(val)`, `num(val)`, `bool(val)`, `to_json(val)`, `from_json(str)`
- Collections: `len(col)`, `keys(obj)`, `values(obj)`, `push(arr, val)`, `pop(arr)`, `join(arr, sep)`, `split(str, sep)`, `slice(str, start, end)`, `locate(str, target)`, `contains(str, target)`
- Filesystem: `read_file(path)`, `write_file(path, content)`, `write_image(path, base64_data_url_or_b64str)`, `make_dir(path)`, `list_dir(path)`
- Encryption & DB: `db_open(path, pwd)` (returns Database object with collections/insert/find/update/delete)
- Browser Automation: `launch(opts)`, `newPage()`, `goto(url)`, `click(sel)`, `fill(sel, val)`, `screenshot(path)`

If the user request requires examining files, writing/testing scripts, performing automated edits, or generating visual assets/images, use the appropriate tools.
"

      let copilot_tools = {
        "read_file": agent_read_file,
        "write_file": agent_write_file,
        "list_directory": agent_list_directory,
        "run_helper_script": agent_run_helper_script,
        "eval_sesi_code": agent_eval_sesi_code,
        "call_image_subagent": agent_generate_image
      }

      if browserAccess == true {
        copilot_tools["browser_goto"] = agent_browser_goto
        copilot_tools["browser_click"] = agent_browser_click
        copilot_tools["browser_fill"] = agent_browser_fill
        copilot_tools["browser_screenshot"] = agent_browser_screenshot
        copilot_tools["browser_get_content"] = agent_browser_get_content
        copilot_tools["browser_close"] = agent_browser_close

        system_prompt = system_prompt + "

You have browser access enabled. Use these tools for visual analysis and verification (such as checking layouts, UI styling, rendered graphics, or media) whenever direct visual inspection is needed to evaluate the application's state:

- `browser_goto`: Navigates to a URL. Arguments JSON schema: {\"url\": string}
- `browser_click`: Clicks an element. Arguments JSON schema: {\"selector\": string}
- `browser_fill`: Fills an input value. Arguments JSON schema: {\"selector\": string, \"value\": string}
- `browser_screenshot`: Captures screenshot. Arguments JSON schema: {\"path\": string} (optional)
- `browser_get_content`: Gets the visible text content of the page. Arguments: {}
- `browser_close`: Closes the active browser. Arguments: {}
"
      }

      current_ws_client = client

      let agent = Agent.create({
        "model": "chat",
        "system": system_prompt,
        "thinkingLevel": "low",
        "cache": false,
        "max_tokens": 4096,
        "tools": copilot_tools,
        "stream": on_agent_chunk
      })

      if len(existing) > 0 {
        let messages = existing[0]["messages"]
        if messages != null {
          for msg in messages {
            let role = "user"
            if msg["isUser"] == false {
              role = "assistant"
            }
            push(agent["history"], {"role": role, "text": msg["text"]})
          }
        }
      }

      let res = ""
      try {
        res = Agent.chat(agent, q)
      } catch(chat_err) {
        res = "⚠️ Co-pilot error: " + str(chat_err)
        client.send(to_json({"type": "chat_chunk", "chunk": res}))
      }

      let assistant_msg = {"text": res, "isUser": false}
      push(chat_doc["messages"], assistant_msg)

      if conversations_col != null && sessionId != null {
        try {
          if len(existing) > 0 {
            conversations_col.update({"session_id": sessionId}, chat_doc)
          } else {
            conversations_col.insert(chat_doc)
          }
        } catch (db_save_err) {}
      }

      client.send(to_json({"type": "chat_end", "response": res}))
      current_ws_client = null
    } else if parsed["type"] == "input" {
      let data_str = parsed["data"]
      if data_str == "backspace" || data_str == "escape" || data_str == "ctrl-c" {
        if data_str == "backspace" {
          if len(term_buffer) > 0 {
            let term_chars = split(term_buffer, "")
            pop(term_chars)
            term_buffer = join(term_chars, "")
            client.send(to_json({"type": "output", "data": "backspace"}))
          }
        } else if data_str == "ctrl-c" {
          client.send(to_json({"type": "output", "data": "^C\r\n$ "}))
          term_buffer = ""
        }
      } else {
        let chars = split(data_str, "")
        for char in chars {
          if char == "\r" || char == "\n" {
            client.send(to_json({"type": "output", "data": "\r\n"}))
            if len(term_buffer) > 0 {
              try {
                let clean_cmd = join(split(term_buffer, "\r"), "")
                clean_cmd = join(split(clean_cmd, "\n"), "")
                let cmd_parts = split(clean_cmd, " ")
                if len(cmd_parts) > 0 {
                  if cmd_parts[0] == "sesi" {
                    if IS_WINDOWS {
                      cmd_parts[0] = "cmd.exe /c node bin/sesi.js"
                    } else {
                      cmd_parts[0] = "node bin/sesi.js"
                    }
                    clean_cmd = join(cmd_parts, " ")
                  } else if cmd_parts[0] == "node" && IS_WINDOWS {
                    cmd_parts[0] = "cmd.exe /c node"
                    clean_cmd = join(cmd_parts, " ")
                  }
                }
                let result = exec(clean_cmd)
                let formatted = join(split(result, "\r"), "")
                formatted = join(split(formatted, "\n"), "\r\n")
                client.send(to_json({"type": "output", "data": formatted + "\r\n"}))
              } catch (e) {
                let err_msg = join(split(str(e), "\r"), "")
                err_msg = join(split(err_msg, "\n"), "\r\n")
                client.send(to_json({"type": "output", "data": "Error: " + err_msg + "\r\n"}))
              }
              term_buffer = ""
            }
            client.send(to_json({"type": "output", "data": "$ "}))
          } else {
            term_buffer = term_buffer + char
            client.send(to_json({"type": "output", "data": char}))
          }
        }
      }
    }
  } catch (e) {
    print "WS Error:" str(e)
  }
}

let http_port = 3050
let ws_port = 3051
try {
  let test_win = exec("cd")
  if test_win != "" {
    ws_port = 3052
  }
} catch (e) {}

print ""
print "  ╔══════════════════════════════════════════╗"
print "  ║                                          ║"
print "  ║   🧠 Sesi Studio v2.0                    ║"
print "  ║   → http://localhost:" str(http_port) "              ║"
print "  ║                                          ║"
print "  ╚══════════════════════════════════════════╝"
print ""

let http = listen(http_port, handle_http)
let ws = api(ws_port, handle_ws)

let exit = input("Enter x to close: ")
if exit == "x" {
  http.close()
  ws.close()
}