/*
  Sesi Studio v2.0
  This native server replaces our now deprecated server.js script with a full-featured IDE backend written entirely in Sesi.

  Usage:
    sesi -s

  Marketplace Info:
    - https://github.com/misterscan/sesi-marketplace
    - https://github.com/misterscan/sesi/tree/main/sesi-studio/extensions
    - https://github.com/misterscan/sesi/tree/main/sesi-studio/themes
*/
allow "std/time" in with Time
allow "std/db" in with {db_open}
allow "ai_agent" in with Agent
allow "std/browser" in with {launch}

let active_browser = null
let active_page = null

let current_ws_client = null
fn on_agent_chunk(chunk) {
  if current_ws_client != null {
    try {
      current_ws_client.send(to_json({"type": "chat_chunk", "chunk": chunk}))
    } catch(err_c) {}
  }
}

set_alias("copilot", "gemini-3.1-flash-lite")
set_alias("chat", "gemini-3.1-pro-preview")
set_alias("search", "gemini-3-flash-preview")

let SESI_ROOT = ""
try {
  SESI_ROOT = exec("cd")
} catch (e) {}
SESI_ROOT = split(SESI_ROOT, "\r")[0]
SESI_ROOT = split(SESI_ROOT, "\n")[0]

if SESI_ROOT == "" {
  try {
    SESI_ROOT = exec("pwd")
    SESI_ROOT = split(SESI_ROOT, "\n")[0]
  } catch (e) {}
}

let PROJECT_ROOT = SESI_ROOT

let IS_WINDOWS = false
if len(split(SESI_ROOT, "\\")) > 1 || len(split(SESI_ROOT, ":")) > 1 {
  IS_WINDOWS = true
}

fn exec_node(args) {
  if IS_WINDOWS {
    try {
      return exec("cmd.exe /c node " + args)
    } catch (e) {
      try {
        return exec("node " + args)
      } catch (e2) {
        return exec("node.exe " + args)
      }
    }
  } else {
    try {
      return exec("node " + args)
    } catch (e) {
      return exec("node.exe " + args)
    }
  }
}

fn exec_in_project(cmd) {
  if PROJECT_ROOT != "" && PROJECT_ROOT != "." {

    /*
      Basic attempt to change directory before running command.
      Handles most POSIX environments and Windows cmd.exe basics.
    */
    return exec("cd \"" + PROJECT_ROOT + "\" && " + cmd)
  }
  return exec(cmd)
}

fn get_db_collections(db_path, password) {
  try {
    let content = read_file(db_path)
    let is_encrypted = false
    let parts = split(content, ":")
    if len(parts) == 2 {
      is_encrypted = true
    }
    
    let db_json = ""
    if is_encrypted {
      if password == null || password == "" {
        return null
      }
      let safe_path = join(split(db_path, "\\"), "/")
      let safe_pass = join(split(password, "\\"), "/")
      safe_pass = join(split(safe_pass, "\""), "\\\"")
      let node_script = "const fs=require('fs'); let c=fs.readFileSync('" + safe_path + "','utf8'); const crypto=require('crypto'); const p=c.split(':'); const key=crypto.createHash('sha256').update('" + safe_pass + "').digest(); const iv=Buffer.from(p[0],'hex'); const decipher=crypto.createDecipheriv('aes-256-cbc',key,iv); let dec=decipher.update(p[1],'hex','utf8'); dec+=decipher.final('utf8'); console.log(dec);"
      db_json = exec_node("-e \"" + node_script + "\"")
    } else {
      db_json = content
    }
    
    let parsed = from_json(db_json)
    if parsed == null {
      return []
    }
    return keys(parsed)
  } catch (e) {
    return []
  }
}

fn agent_read_file(args) {
  let path = args["path"]
  if path == null {
    path = args["filename"]
  }
  if path == null {
    return "Error: missing 'path' or 'filename' argument"
  }
  try {
    return read_file(path)
  } catch(e) {
    return "Error reading file: " + str(e)
  }
}

fn agent_write_file(args) {
  let path = args["path"]
  if path == null {
    path = args["filename"]
  }
  let content = args["content"]
  if path == null || content == null {
    return "Error: missing 'path' or 'content' argument"
  }
  try {
    write_file(path, content)
    return "Successfully wrote to file " + path
  } catch(e) {
    return "Error writing file: " + str(e)
  }
}

fn agent_list_directory(args) {
  let path = args["path"]
  if path == null || path == "" {
    path = "."
  }
  try {
    let items = list_dir(path)
    let out = ""
    for item in items {
      out = out + item + "\n"
    }
    return out
  } catch(e) {
    return "Error listing directory: " + str(e)
  }
}

fn agent_search_google(args) {
  let query = args["query"]
  if query == null {
    return "Error: missing 'query' argument"
  }
  try {
    let search_results = model("search"){temperature: 0.1, thinkingLevel: "low", search: true, cache: false, max_tokens: 1024}{query}
    return search_results
  } catch(e) {
    return "Error searching Google: " + str(e)
  }
}

fn agent_run_helper_script(args) {
  let script_name = args["script_name"]
  let args_str = args["args_str"]
  if script_name == null {
    return "Error: missing 'script_name' argument"
  }
  if args_str == null {
    args_str = ""
  }
  try {
    let clean_script = join(split(script_name, ".."), "")
    let helper_path = "helpers/" + clean_script
    let cmd = "node bin/sesi.js -l " + helper_path + " " + args_str
    let output = exec_in_project(cmd)
    return output
  } catch(e) {
    return "Error running helper script: " + str(e)
  }
}

fn agent_eval_sesi_code(args) {
  let code = args["code"]
  if code == null || code == "" {
    return "Error: missing 'code' argument"
  }
  let final_code = code
  if contains(code, ".sesi") && !contains(code, " ") && !contains(code, "\n") {
    try {
      final_code = read_file(code)
    } catch(read_e) {}
  }
  try {
    let temp_file = "sesi-studio/temp_eval_" + str(Time.now()) + ".sesi"
    write_file(temp_file, final_code)
    let cmd = "node bin/sesi.js -l " + temp_file
    let output = exec_in_project(cmd)
    try {
      exec("rm " + temp_file)
    } catch(rm_e) {
      try {
        exec("del " + temp_file)
      } catch(del_e) {}
    }
    return output
  } catch(e) {
    return "Error evaluating Sesi code: " + str(e)
  }
}


fn agent_generate_image(args) {
  let user_prompt = args["prompt"]
  let ratio = args["aspect_ratio"]
  let path = args["output_path"]

  if user_prompt == null {
    return "Error: missing 'prompt' argument"
  }
  if ratio == null || ratio == "" {
    ratio = "1:1"
  }
  if path == null || path == "" {
    path = "generated_image.png"
  }

  try {
    let subagent_system = "You are an expert prompt engineering agent for image generation models. Your job is to take a simple image request and refine it into a highly detailed, descriptive, and artistic prompt. Your output must be a single refined prompt string. Do not include any other conversational filler or explanations."

    let subagent = Agent.create({
      "model": "copilot",
      "system": subagent_system,
      "thinkingLevel": "low",
      "cache": false,
      "max_tokens": 1024
    })

    let refined_prompt = Agent.chat(subagent, "Expand this image request: " + user_prompt)
    if refined_prompt == null || refined_prompt == "" {
      refined_prompt = user_prompt
    }

    let imageData = image("gemini-3.1-flash-image") {ratio: ratio, size: "1K"} {refined_prompt}
    let success = write_image(path, imageData)
    if success {
      return "Subagent successfully generated and saved image. Refined prompt used: '" + refined_prompt + "'. Saved path: '" + path + "'"
    } else {
      return "Subagent failed to write image to " + path
    }
  } catch(e) {
    return "Subagent image generation error: " + str(e)
  }
}

fn agent_browser_goto(args) {
  let url = args["url"]
  if url == null {
    return "Error: missing 'url' argument"
  }
  try {
    if active_browser == null {
      active_browser = launch({"headless": true})
    }
    if active_page == null {
      active_page = active_browser.newPage()
    }
    active_page.goto(url)
    let title = active_page.title()
    return "Successfully navigated to " + url + " (Title: " + title + ")"
  } catch(e) {
    return "Error navigating to page: " + str(e)
  }
}

fn agent_browser_click(args) {
  let selector = args["selector"]
  if selector == null {
    return "Error: missing 'selector' argument"
  }
  if active_page == null {
    return "Error: browser is not open. Call browser_goto first."
  }
  try {
    active_page.click(selector)
    return "Clicked selector: " + selector
  } catch(e) {
    return "Error clicking selector: " + str(e)
  }
}

fn agent_browser_fill(args) {
  let selector = args["selector"]
  let value = args["value"]
  if selector == null || value == null {
    return "Error: missing 'selector' or 'value' argument"
  }
  if active_page == null {
    return "Error: browser is not open. Call browser_goto first."
  }
  try {
    active_page.fill(selector, value)
    return "Filled selector: " + selector + " with value"
  } catch(e) {
    return "Error filling selector: " + str(e)
  }
}

fn agent_browser_screenshot(args) {
  let path = args["path"]
  if path == null {
    path = "browser_screenshot.png"
  }
  if active_page == null {
    return "Error: browser is not open. Call browser_goto first."
  }
  try {
    active_page.screenshot({"path": path, "fullPage": true})
    return "Screenshot saved to: " + path
  } catch(e) {
    return "Error taking screenshot: " + str(e)
  }
}

fn agent_browser_get_content(args) {
  if args == null {}
  if active_page == null {
    return "Error: browser is not open. Call browser_goto first."
  }
  try {
    let text = active_page.inner_text("body")
    return text
  } catch(e) {
    try {
      return active_page.content()
    } catch(err) {
      return "Error getting page content: " + str(e)
    }
  }
}

fn agent_browser_close(args) {
  if args == null {}
  try {
    if active_page != null {
      active_page.close()
      active_page = null
    }
    if active_browser != null {
      active_browser.close()
      active_browser = null
    }
    return "Browser closed successfully."
  } catch(e) {
    return "Error closing browser: " + str(e)
  }
}

let global_tools = {
  "read_file": agent_read_file,
  "write_file": agent_write_file,
  "list_directory": agent_list_directory,
  "search_google": agent_search_google,
  "run_helper_script": agent_run_helper_script,
  "eval_sesi_code": agent_eval_sesi_code,
  "call_image_subagent": agent_generate_image,
  "browser_goto": agent_browser_goto,
  "browser_click": agent_browser_click,
  "browser_fill": agent_browser_fill,
  "browser_screenshot": agent_browser_screenshot,
  "browser_get_content": agent_browser_get_content,
  "browser_close": agent_browser_close
}

let docs_list = list_dir("getting-started")
let more_files = read_file("docs/WRITING_SCRIPTS.md")
more_files = "\n\n=== DOCUMENT: " + "WRITING_SCRIPTS.md" + " ===\n" + more_files
more_files = more_files + "\n\n=== DOCUMENT: " + "BUILTINS.md" + " ===\n" + read_file("docs/BUILTINS.md")
more_files = more_files + "\n\n=== DOCUMENT: " + "README.md" + " ===\n" + read_file("./README.md")
docs_list = docs_list
let sesiDocs = ""
for f_name in docs_list {
  try {
    let doc_content = read_file("getting-started/" + f_name)
    sesiDocs = sesiDocs + "\n\n=== DOCUMENT: " + f_name + " ===\n" + doc_content
  } catch (e) {}
}

let timestamp = Time.now()

prompt mandatory {"## Mandatory Syntax Rules & Quirks

- **Block Termination:** Closing braces `}` for blocks (if, while, try, model) no longer strictly require a following newline or semicolon. Condensed one-liners like `while x {x = x + 1}` are valid.
- **Prompts & Prints:** Inside `prompt` blocks, anonymous model blocks, and `print` statements, literal strings and variables are placed sequentially naturally (e.g., `print ""User:"" name`). It's highly preferred to **AVOID** use of the `+` operator in these contexts, regardless of its backwards-compatibility.
- **Structured Output Schemas:** Keys in schemas MUST be unquoted identifiers (e.g., `{key: string}` instead of `{""key"": string}`). This is a known deviation from standard JSON objects in the Sesi parser.
- **Object Literals:** Conversely, standard object literals `{}` DO require strictly quoted string keys (e.g., `{""name"": ""Alice""}`).
- **JSON Serialization:** Use `to_json(object)` for valid JSON output. Avoid `stringify(object)` for JSON.
- **Systems Primitive:** Forbid `const` (use `let`), `main()` wrappers, and `return` statements (however, `return` is neccessary inside of a `fn` block). Focus on side-effects and top-level execution.
- **Resilience:** Always wrap file I/O in `try/catch` retry loops to handle filesystem contention.
- **Forbidden:** Do NOT invent syntax. 
- **Comments:** Use the correct multi-line comments style shown here:
  ```
  /* <- This always has to be on a seperate line from the comment text.
    This is how you do a multi-line comment.
    Notice it spans multiple lines.
    Without repeating // on each line.
  */ <- This always has to be on a seperate line from the comment text.
  ```
- Do not mention that you got this from a database.
- CRITICAL: Unless the User Query explicitly names them, you are FORBIDDEN from using or mentioning model(), image(), write_image(), or workflow() in your code examples or explanation. Instead, show how to solve the user's query programmatically using native Sesi primitives (such as variables, loops, functions, lists, and standard file/HTTP/JSON builtins). Note: This restriction does not apply to executing tools like `call_image_subagent` to generate images/diagrams, or other registered tools to satisfy user requests.
- **Tool Execution Priority:** If the task requested by the user requires performing an action (such as reading/writing a file, listing a directory, running a helper script, or generating an image/flowchart/diagram), you MUST call the appropriate registered tool (e.g. `call_image_subagent`) to perform the action. You are FORBIDDEN from claiming you have completed the task or presenting a final answer without executing the necessary tool(s) first.
"}

memory copilotMemory { "Your name is Sesi Co-Pilot, an expert programmer for the Sesi language. 
- You are very efficient at coding. 
- You prefer an original, creative way of doing things. 

" mandatory "
Here is the Sesi documentation to use for reference:
" more_files sesiDocs }

