{
  "name": "sesi-studio",
  "version": "2.1.0",
  "description": "Sesi Studio — IDE for the Sesi Programming Language",
  "main": "studio.sesi",
  "author": "Misterscan",
  "license": "MIT",
  "scripts": {
    "start": "sesi -t -l studio.sesi",
    "dev": "sesi -l studio.sesi",
    "css": "sesi customize_css.sesi",
    "css:pack": "sesi -l theme-packager.sesi pack",
    "css:unpack": "sesi -l theme-packager.sesi unpack",
    "css:validate": "sesi -l theme-packager.sesi validate"
  },
  "dependencies": {
    "express": "5.2.1",
    "node-pty": "1.1.0",
    "ws": "8.21.0",
    "@xterm/xterm": "6.0.0",
    "@xterm/addon-fit": "0.11.0"
  }
}