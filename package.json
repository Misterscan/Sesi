{
  "name": "@misterscan/sesi",
  "version": "1.5.7",
  "description": "Sesi: A Concise, Legible Programming Language",
  "main": "dist/index.js",
  "bin": {
    "sesi": "bin/sesi.js"
  },
  "files": [
    "dist",
    "bin",
    "docs",
    "examples/main",
    "examples/optional",
    "sesi-db",
    "main/tests",
    ".agents",
    "chatbot",
    ".github",
    "tutorial",
    "example.js",
    "example-ai.js",
    "examples.sesi",
    "scaffold.sesi",
    "getting-started",
    "sf2"
  ],
  "scripts": {
    "lint": "sesi -l bin/lint.sesi",
    "build": "tsc",
    "commit:message": "sesi -l helpers/commit_message.sesi --staged",
    "debug": "SESI_DEBUG=1 sesi",
    "dev": "dotenvx run -- npm run build --watch",
    "test": "npx ts-node tests/basic.test.ts && npx ts-node tests/module.test.ts && npx ts-node tests/cache.test.ts && npx ts-node tests/http.test.ts && npx ts-node tests/workflow.test.ts && npx ts-node tests/security.test.ts",
    "test:watch": "npx ts-node tests/basic.test.ts --watch",
    "sesi": "sesi",
    "sesi:local": "sesi -l",
    "sesi:dry": "sesi -c",
    "sesi:eval": "sesi -e",
    "sesi:parse": "sesi -r",
    "sesi:encrypt": "sesi -enc",
    "sesi:decrypt": "sesi -dec",
    "studio": "sesi -l sesi-studio/studio.sesi",
    "studio:css": "sesi -l sesi-studio/customize_css.sesi",
    "studio:css:pack": "sesi -l sesi-studio/theme-packager.sesi pack",
    "studio:css:unpack": "sesi -l sesi-studio/theme-packager.sesi unpack",
    "studio:css:validate": "sesi -l sesi-studio/theme-packager.sesi validate",
    "studio:ext:pack": "sesi -l sesi-studio/extension-packager.sesi pack",
    "studio:ext:unpack": "sesi -l sesi-studio/extension-packager.sesi unpack",
    "studio:ext:validate": "sesi -l sesi-studio/extension-packager.sesi validate",
    "copilot": "sesi chatbot/sesi_db_chatbot.sesi",
    "build:exe": "node ./scripts/build-binaries.mjs",
    "msi:eula": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& 'C:\\Program Files\\WiX Toolset v7.0\\bin\\wix.exe' eula accept wix7\"",
    "build:msi": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& 'C:\\Program Files\\WiX Toolset v7.0\\bin\\wix.exe' build .\\SesiInstaller.wxs -o .\\SesiInstaller.msi\"",
    "build:installer": "npm run build:exe && npm run msi:eula && npm run build:msi",
    "build:mac:pkg": "node ./scripts/build-macos-pkg.mjs",
    "build:mac:installer": "npm run build:exe && npm run build:mac:pkg",
    "extension:package": "cd editors/vscode && npx @vscode/vsce package",
    "repl": "sesi",
    "example": "node --no-deprecation example.js",
    "example:ai": "node --no-deprecation example-ai.js",
    "example:all": "sesi -l examples.sesi",
    "tutorial": "sesi -l tutorial/interactive_web_tutorial.sesi",
    "tutorial:cli": "sesi -l tutorial/tutorial.sesi",
    "upload": "npm run build && npm publish --access public"
  },
  "keywords": [
    "sesi",
    "programming-language",
    "workflow-automation",
    "concise",
    "legible",
    "ast-interpreter",
    "misterscan",
    "cli"
  ],
  "author": "Misterscan",
  "license": "MIT",
  "dependencies": {
    "@dotenvx/dotenvx": "1.75.1",
    "@dotenvx/dotenvx-armor": "0.56.1",
    "@dotenvx/dotenvx-ops": "0.56.1",
    "@google/genai": "2.9.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "globals": "^17.6.0",
    "rcedit": "^5.0.2",
    "typescript": "6.0.3"
  },
  "allowScripts": {
    "fsevents@2.3.2": true,
    "protobufjs@7.6.4": true,
    "@google/genai@2.9.0": true
  }
}
