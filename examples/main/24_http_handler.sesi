/* 
  Example 24: HTTP Handler
  Dynamic request handler for HTTP server
*/

allow "std/time" in with {sleep}

export fn handleRequest(req) {
  print "Received request on path:" req.path "with method:" req.method

  if req.path == "/" {
    return {
      "status": 200,
      "headers": {
        "Content-Type": "text/html"
      },
      "body": "<h1>Welcome to Sesi Native HTTP Server!</h1><p>Try visiting <a href='/api/info'>/api/info</a> or <a href='/api/echo?name=Sesi'>/api/echo?name=Sesi</a></p>"
    }
  }

  if req.path == "/api/info" {
    return {
      "status": 200,
      "body": {
        "language": "Sesi",
        "version": "1.6.3",
        "features": ["async/await", "native HTTP server", "structured output", "tool calls", "live reload"]
      }
    }
  }

  if req.path == "/api/echo" {
    let name = "Guest"
    if req.query.name {
      name = req.query.name
    }
    return {
      "status": 200,
      "body": {
        "message": "Hello, " + name,
        "method": req.method,
        "query": req.query,
        "headers": req.headers
      }
    }
  }

  return {
    "status": 404,
    "body": "Page not found"
  }
}
