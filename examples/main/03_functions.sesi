// Functions
fn add(a: number, b: number) {print a + b}
fn greet(name: string = "World") {print "Hello" name "!"}

add(5, 3)
greet()
greet("Alice")

// Advanced Functions
fn calculate(operation: string, a: number, b: number) {
    if operation == "add" {
        print a + b
    } else if operation == "subtract" {
        print a - b
    } else if operation == "multiply" {
        print a * b
    } else if operation == "divide" {
        print a / b
    } else {
        print "Invalid operation"
    }
}

calculate("multiply", 5, 3)

// Define your functions and call it using a custom tool
fn getSesi() {
    return "1.5.3"
}

define_tool("get-sesi", getSesi, "Get the current Sesi version")
let v = tool_call(getSesi)() // or simply getSesi() since tool_call is optional for direct calls

print "Current version:" v