/* 
    Example 16: Modules and Scoped Lib Support

Demonstrates:
    1. Allowing access to variables/functions from standard library modules using allow.
    2. Allowing access to modules into scoped library namespaces using allow.
    3. Allowing access to custom Sesi modules using relative paths. 
*/

print "=== 1. Standard Math Module ==="

allow "std/math" in with Math

print "PI constant:" str(Math.PI)
print "Euler's number:" str(Math.E)
print "Square root of 144:" str(Math.sqrt(144))
print "2 raised to power of 10:" str(Math.pow(2, 10))
print "Sine of PI/2:" str(Math.sin(Math.PI / 2.0))

print "=== 2. Scoped Lib Scoping ==="
allow "std/math" in with Math

print "Area of circle with radius 5 (using Math lib namespace):" str(Math.PI * Math.pow(5, 2))

print "=== 3. Standard JSON Module ==="
allow "std/json" in with Json

let original = {"project": "Sesi Language", "version": "1.6.1", "features": ["modules", "http", "parallel"]}
let json_str = Json.stringify(original)
print "Serialized JSON string:"
print json_str
let restored = Json.parse(json_str)
print "Deserialized Project Name:" restored["project"]
print "Deserialized Version:" restored["version"]

print "=== 4. Custom Sesi Module ==="

/* Relative imports let you reuse Sesi code across files cleanly.
We will import custom exported variables and functions from a local module. */
allow "main/tests/temp_math_mod" in with LocalMath

print "Imported magic number from local module:" str(LocalMath.magic_number)
print "Running imported multiply(5, 5):" str(LocalMath.multiply(5, 5))

print "=== 5. Third-Party Modules & Sesi Packages ==="

/* Sesi supports downloading and importing third-party packages from Git.
To install a package, run:
    sesi install github:owner/repo
The package will be installed in `sesi_modules/repo`.
You can then import it like standard local modules: */

// allow "repo" in with MyRepo