  "optional": [
    "Model Call",
    "Code Generation",
    "Folder Explainer",
    "Image Generation",
    "Model Aliases",
    "Reasoning + Custom Tools",
    "Streaming"
  ]
}

let main = examples["main"]
let optional = examples["optional"]

fn skip(input) {
    let input = ""
    if input == "skip" {
        return skip
    } else {
        continue
    }
}

try {
    print "Launching example .sesi files...
    If you have the reasoning capabilites commented out, this should be quick.
    If you have the reasoning capabilites uncommented, this could take a while"
