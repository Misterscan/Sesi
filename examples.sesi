let examples = {
  "main": [
    "Hello, Sesi!",
    "Variables",
    "Functions",
    "Conditionals",
    "Loops",
    "Arrays & Objects",
    "Prompts",
    "Structured Output",
    "Memory Storage",
    "Classification",
    "Data Pipeline",
    "Modules",
    "HTTP Client",
    "Parallel Requests",
    "Web Search",
    "Custom Tools",
    "File Conversion",
